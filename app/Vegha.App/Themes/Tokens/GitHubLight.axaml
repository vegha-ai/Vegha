<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- GitHub Light — clean neutral greys + the canonical GitHub blue accent. -->

    <SolidColorBrush x:Key="Bg0Brush" Color="#eaeef2" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#f6f8fa" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#ffffff" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#fafbfc" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#eaeef2" />
    <SolidColorBrush x:Key="BgInputBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#eaeef2" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style). GitHub Primer tones:
         canvas.subtle #f6f8fa for title/status, a mid #f0f3f6 for side/header, and the
         muted #eaeef2 for activity/tab bars; editor (Bg1 #f6f8fa) is the lightest. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#f6f8fa" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#eaeef2" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#f0f3f6" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#f0f3f6" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#eaeef2" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#f6f8fa" />

    <!-- Borders stepped up for visible field edges on white (audit §07.1). -->
    <SolidColorBrush x:Key="Border0Brush" Color="#d0d7de" />
    <SolidColorBrush x:Key="Border1Brush" Color="#a0aab4" />
    <SolidColorBrush x:Key="Border2Brush" Color="#828c96" />

    <SolidColorBrush x:Key="Text0Brush" Color="#1f2328" />
    <SolidColorBrush x:Key="Text1Brush" Color="#424a53" />
    <SolidColorBrush x:Key="Text2Brush" Color="#656d76" />
    <SolidColorBrush x:Key="Text3Brush" Color="#8c959f" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#ffffff" />

    <SolidColorBrush x:Key="AccentBrush" Color="#0969da" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0550ae" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#220969da" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#3a0969da" />

    <!-- Fluent SystemAccentColor override — checked marks, toggle switches, sliders,
         focus rings and selection tint with the theme accent instead of Fluent's default
         system blue. Dark1-3 step toward pressed shades, Light1-3 toward hover tints;
         derived from AccentBrush (10/20/30% blends). -->
    <Color x:Key="SystemAccentColor">#0969da</Color>
    <Color x:Key="SystemAccentColorDark1">#085ec4</Color>
    <Color x:Key="SystemAccentColorDark2">#0754ae</Color>
    <Color x:Key="SystemAccentColorDark3">#064a99</Color>
    <Color x:Key="SystemAccentColorLight1">#2278de</Color>
    <Color x:Key="SystemAccentColorLight2">#3a87e1</Color>
    <Color x:Key="SystemAccentColorLight3">#5396e5</Color>

    <!-- Fluent input-state overrides (audit §04): keep the input background on hover/focus
         and use the accent border instead of Fluent's focused-state defaults. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#ffffff" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#ffffff" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#828c96" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0969da" />

    <SolidColorBrush x:Key="MethodGetBrush" Color="#1a7f37" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#bf8700" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#0969da" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#8250df" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#cf222e" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#0a6e7b" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#57606a" />

    <!-- Status / semantic — GitHub success/attention/danger + blue info + soft tints. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#1a7f37" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#bf8700" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#cf222e" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#0969da" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#261a7f37" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#26bf8700" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#26cf222e" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#260969da" />

    <SolidColorBrush x:Key="CodeBgBrush" Color="#f6f8fa" />

    <!-- Syntax highlighting — GitHub Light family. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#8c959f" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#0969da" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#0969da" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#1a7f37" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#1a7f37" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#bf8700" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#8250df" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#0a6e7b" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#bf8700" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#656d76" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#330969da" />

    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
