<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Solarized Light — companion to Solarized Dark. Warm beige backgrounds. -->

    <SolidColorBrush x:Key="Bg0Brush" Color="#e6dfc5" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#fdf6e3" />
    <!-- Bg2 is the elevated/card/popup surface — kept warm off-white (not pure #fff) so
         menus, flyouts, cards and dialog command bars read as solarized paper, not white. -->
    <SolidColorBrush x:Key="Bg2Brush" Color="#f7f0dc" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#f1ead4" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#eee8d5" />
    <!-- Inputs & editors get the solarized writing surfaces, not raw #fff: input fields
         use a tinted inset (base2-ish) and the active tab lifts to the editor cream. -->
    <SolidColorBrush x:Key="BgInputBrush" Color="#ece5cf" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#fdf6e3" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#eee8d5" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style) so the shell reads as
         layered paper instead of one flat fill. Authentic Solarized Light values: activity
         bar is the deepest beige, the editor-tab strip a touch lighter, and side/title/
         status/header share base2 (#eee8d5); the editor (Bg1 #fdf6e3) stays the lightest. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#eee8d5" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#ddd6c1" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#eee8d5" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#eee8d5" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#d9d2c2" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#eee8d5" />

    <!-- Borders stepped up for visible field edges on cream (audit §07.1). -->
    <SolidColorBrush x:Key="Border0Brush" Color="#e6dec7" />
    <SolidColorBrush x:Key="Border1Brush" Color="#c8bf9c" />
    <SolidColorBrush x:Key="Border2Brush" Color="#a89f7f" />

    <SolidColorBrush x:Key="Text0Brush" Color="#073642" />
    <SolidColorBrush x:Key="Text1Brush" Color="#586e75" />
    <SolidColorBrush x:Key="Text2Brush" Color="#657b83" />
    <SolidColorBrush x:Key="Text3Brush" Color="#93a1a1" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#fdf6e3" />

    <SolidColorBrush x:Key="AccentBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1d75b3" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#22268bd2" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#3a268bd2" />

    <!-- Fluent input-state overrides (audit §04): keep the input background on hover/focus
         and use the accent border instead of Fluent's focused-state defaults. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#ece5cf" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#ece5cf" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#a89f7f" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#268bd2" />

    <SolidColorBrush x:Key="MethodGetBrush" Color="#859900" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#b58900" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#6c71c4" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#dc322f" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#2aa198" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#657b83" />

    <!-- Status / semantic — Solarized green/yellow/red + signature blue info + soft tints. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#859900" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#b58900" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#dc322f" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#26859900" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#26b58900" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#26dc322f" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#26268bd2" />

    <!-- Editor surface = authentic Solarized editor.background (base3), clearly warm cream
         so the request/response code panes read as paper instead of white. -->
    <SolidColorBrush x:Key="CodeBgBrush" Color="#fdf6e3" />

    <!-- Syntax highlighting — Solarized family. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#93a1a1" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#859900" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#859900" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#b58900" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#6c71c4" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#2aa198" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#b58900" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#657b83" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#33268bd2" />

    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
