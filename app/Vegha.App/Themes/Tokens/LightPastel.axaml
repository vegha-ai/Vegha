<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Pastel — soft pastel palette with warm off-white backgrounds, lavender accent. -->

    <SolidColorBrush x:Key="Bg0Brush" Color="#f3eef5" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#faf6fb" />
    <!-- Bg2 is the elevated/card/popup surface — kept faintly tinted (not pure #fff) so
         menus, flyouts, cards and dialog command bars read as pastel, not stark white. -->
    <SolidColorBrush x:Key="Bg2Brush" Color="#f7f1f9" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#f2ecf6" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#efe7f3" />
    <!-- Inputs & editors use the pastel writing surfaces, not raw #fff. -->
    <SolidColorBrush x:Key="BgInputBrush" Color="#efe7f4" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#faf6fb" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#efe7f3" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style). Soft lavender steps
         below the editor (Bg1 #faf6fb): deepest on the activity/tab bars, mid on the
         side/header, lightest pastel on title/status. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#f3eef5" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#ece2f1" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#f3edf6" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#f3edf6" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#ece2f1" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#f3eef5" />

    <!-- Borders stepped up for visible field edges on white (audit §07.1). -->
    <SolidColorBrush x:Key="Border0Brush" Color="#e9deef" />
    <SolidColorBrush x:Key="Border1Brush" Color="#c7b2d6" />
    <SolidColorBrush x:Key="Border2Brush" Color="#a98fbb" />

    <SolidColorBrush x:Key="Text0Brush" Color="#241a2c" />
    <SolidColorBrush x:Key="Text1Brush" Color="#4b3c5a" />
    <SolidColorBrush x:Key="Text2Brush" Color="#7a6b87" />
    <SolidColorBrush x:Key="Text3Brush" Color="#a698b0" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#ffffff" />

    <SolidColorBrush x:Key="AccentBrush" Color="#a78bfa" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#8b5cf6" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#22a78bfa" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#3aa78bfa" />

    <!-- Fluent SystemAccentColor override — checked marks, toggle switches, sliders,
         focus rings and selection tint with the theme accent instead of Fluent's default
         system blue. Dark1-3 step toward pressed shades, Light1-3 toward hover tints;
         derived from AccentBrush (10/20/30% blends). -->
    <Color x:Key="SystemAccentColor">#a78bfa</Color>
    <Color x:Key="SystemAccentColorDark1">#967de1</Color>
    <Color x:Key="SystemAccentColorDark2">#866fc8</Color>
    <Color x:Key="SystemAccentColorDark3">#7561af</Color>
    <Color x:Key="SystemAccentColorLight1">#b097fa</Color>
    <Color x:Key="SystemAccentColorLight2">#b9a2fb</Color>
    <Color x:Key="SystemAccentColorLight3">#c1aefc</Color>

    <!-- Fluent input-state overrides (audit §04): keep the input background on hover/focus
         and use the accent border instead of Fluent's focused-state defaults. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#efe7f4" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#efe7f4" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#a98fbb" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#a78bfa" />

    <SolidColorBrush x:Key="MethodGetBrush" Color="#10b981" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#f59e0b" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#6366f1" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#a78bfa" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#f87171" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#22d3ee" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#94a3b8" />

    <!-- Status / semantic — pastel green/amber/red + indigo info + soft tints. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#10b981" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#f59e0b" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#f87171" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#6366f1" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#2610b981" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#26f59e0b" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#26f87171" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#266366f1" />

    <SolidColorBrush x:Key="CodeBgBrush" Color="#faf6fb" />

    <!-- Syntax highlighting — pastel family. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#a698b0" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#6366f1" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#a78bfa" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#10b981" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#10b981" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#f59e0b" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#a78bfa" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#22d3ee" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#f59e0b" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#7a6b87" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#44a78bfa" />

    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
