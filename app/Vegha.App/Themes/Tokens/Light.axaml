<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Default Light variant — original palette. -->

    <SolidColorBrush x:Key="Bg0Brush" Color="#e8eaee" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#f4f5f7" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#ffffff" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#fafbfc" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#eef0f3" />
    <SolidColorBrush x:Key="BgInputBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#eef0f3" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style). Soft neutral greys
         stepped below the editor (Bg1 #f4f5f7) so the frame recedes and content lifts. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#e8eaee" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#e1e4e9" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#eceef2" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#eceef2" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#e6e8ed" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#e8eaee" />

    <!-- Borders — stepped up from the original near-invisible #d6d9df/#b8bdc6 so
         inputs read as bordered fields on white instead of floating (audit §07.1). -->
    <SolidColorBrush x:Key="Border0Brush" Color="#e6e8ec" />
    <SolidColorBrush x:Key="Border1Brush" Color="#c2c7d0" />
    <SolidColorBrush x:Key="Border2Brush" Color="#a6acb8" />

    <SolidColorBrush x:Key="Text0Brush" Color="#15181d" />
    <SolidColorBrush x:Key="Text1Brush" Color="#41464f" />
    <SolidColorBrush x:Key="Text2Brush" Color="#6b7280" />
    <SolidColorBrush x:Key="Text3Brush" Color="#9aa1ac" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#ffffff" />

    <SolidColorBrush x:Key="AccentBrush" Color="#3b82f6" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2563eb" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#1F3b82f6" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#383b82f6" />

    <!-- Fluent SystemAccentColor override — checked marks, toggle switches, sliders,
         focus rings and selection tint with the theme accent instead of Fluent's default
         system blue. Dark1-3 step toward pressed shades, Light1-3 toward hover tints;
         derived from AccentBrush (10/20/30% blends). -->
    <Color x:Key="SystemAccentColor">#3b82f6</Color>
    <Color x:Key="SystemAccentColorDark1">#3575dd</Color>
    <Color x:Key="SystemAccentColorDark2">#2f68c5</Color>
    <Color x:Key="SystemAccentColorDark3">#295bac</Color>
    <Color x:Key="SystemAccentColorLight1">#4f8ef7</Color>
    <Color x:Key="SystemAccentColorLight2">#629bf8</Color>
    <Color x:Key="SystemAccentColorLight3">#76a8f9</Color>

    <!-- Fluent input-state overrides (audit §04): keep the input background on hover/focus
         and use the accent border instead of Fluent's focused-state defaults. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#ffffff" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#ffffff" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#a6acb8" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#3b82f6" />

    <SolidColorBrush x:Key="MethodGetBrush" Color="#16a34a" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#ca8a04" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#2563eb" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#7c3aed" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#dc2626" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#0891b2" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#475569" />

    <!-- Status / semantic — distinct from method hues; light soft tints are the
         opaque pastels from the audit so they stay crisp on white. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#1f9d57" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#d08700" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#dc3a3a" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#2f6df0" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#e7f5ed" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#fdf3e0" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#fdeaea" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#eaf1fe" />

    <SolidColorBrush x:Key="CodeBgBrush" Color="#f8f9fb" />

    <!-- Syntax highlighting — VS Code Light palette. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#008000" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#800000" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#0070C9" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#0451A5" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#A31515" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#098658" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#0000FF" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#0070C9" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#795E26" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#15181D" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#333b82f6" />

    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
