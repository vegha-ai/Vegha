<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Solarized Dark — Ethan Schoonover's classic warm-cyan dark palette.
         Backgrounds shade toward dark teal; accent is the signature solarized blue. -->

    <SolidColorBrush x:Key="Bg0Brush" Color="#001f27" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#002b36" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#073642" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#0a3d4a" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#114652" />
    <SolidColorBrush x:Key="BgInputBrush" Color="#001f27" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#073642" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#001f27" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style). Preserves the current
         Solarized Dark look: base03-deep (#001f27) frames the title bar; side/activity/
         header/tab/status share base02 (#073642), above the editor (Bg1) and below cards. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#001f27" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#073642" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#073642" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#073642" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#073642" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#073642" />

    <SolidColorBrush x:Key="Border0Brush" Color="#0c4554" />
    <SolidColorBrush x:Key="Border1Brush" Color="#155262" />
    <SolidColorBrush x:Key="Border2Brush" Color="#1e6577" />

    <SolidColorBrush x:Key="Text0Brush" Color="#eee8d5" />
    <SolidColorBrush x:Key="Text1Brush" Color="#93a1a1" />
    <SolidColorBrush x:Key="Text2Brush" Color="#839496" />
    <SolidColorBrush x:Key="Text3Brush" Color="#586e75" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#002b36" />

    <SolidColorBrush x:Key="AccentBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1d75b3" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#22268bd2" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#3a268bd2" />

    <!-- Fluent SystemAccentColor override — checked marks, toggle switches, sliders,
         focus rings and selection tint with the theme accent instead of Fluent's default
         system blue. Dark1-3 step toward pressed shades, Light1-3 toward hover tints;
         derived from AccentBrush (10/20/30% blends). -->
    <Color x:Key="SystemAccentColor">#268bd2</Color>
    <Color x:Key="SystemAccentColorDark1">#227dbd</Color>
    <Color x:Key="SystemAccentColorDark2">#1e6fa8</Color>
    <Color x:Key="SystemAccentColorDark3">#1b6193</Color>
    <Color x:Key="SystemAccentColorLight1">#3c97d6</Color>
    <Color x:Key="SystemAccentColorLight2">#51a2db</Color>
    <Color x:Key="SystemAccentColorLight3">#67aee0</Color>

    <!-- Fluent input-state overrides (audit §04): keep the input background on hover/focus
         and use the accent border instead of Fluent's focused-state defaults. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#001f27" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#001f27" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#1e6577" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#268bd2" />

    <SolidColorBrush x:Key="MethodGetBrush" Color="#859900" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#b58900" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#6c71c4" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#dc322f" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#2aa198" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#657b83" />

    <!-- Status / semantic — Solarized green/yellow/red + signature blue info + soft tints. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#859900" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#b58900" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#dc322f" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#26859900" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#26b58900" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#26dc322f" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#26268bd2" />

    <SolidColorBrush x:Key="CodeBgBrush" Color="#001f27" />

    <!-- Syntax highlighting — Solarized family. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#586e75" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#859900" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#859900" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#b58900" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#6c71c4" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#2aa198" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#b58900" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#839496" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#52268bd2" />

    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
