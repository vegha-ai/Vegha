<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Nord — Arctic Bluish palette. Cool slate backgrounds, frosty cyan accent. -->

    <SolidColorBrush x:Key="Bg0Brush" Color="#242933" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#2e3440" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#3b4252" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#434c5e" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#4c566a" />
    <SolidColorBrush x:Key="BgInputBrush" Color="#242933" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#3b4252" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#242933" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style). Preserves the current
         Nord look: Polar Night #242933 frames the title bar; side/activity/header/tab/status
         share the #3b4252 mid-surface, above the editor (Bg1) and below cards. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#242933" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#3b4252" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#3b4252" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#3b4252" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#3b4252" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#3b4252" />

    <SolidColorBrush x:Key="Border0Brush" Color="#3b4252" />
    <SolidColorBrush x:Key="Border1Brush" Color="#434c5e" />
    <SolidColorBrush x:Key="Border2Brush" Color="#4c566a" />

    <SolidColorBrush x:Key="Text0Brush" Color="#eceff4" />
    <SolidColorBrush x:Key="Text1Brush" Color="#d8dee9" />
    <SolidColorBrush x:Key="Text2Brush" Color="#9aa5b7" />
    <SolidColorBrush x:Key="Text3Brush" Color="#6c7689" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#2e3440" />

    <SolidColorBrush x:Key="AccentBrush" Color="#88c0d0" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#6fb1c6" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#2288c0d0" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#3a88c0d0" />

    <!-- Fluent SystemAccentColor override — checked marks, toggle switches, sliders,
         focus rings and selection tint with the theme accent instead of Fluent's default
         system blue. Dark1-3 step toward pressed shades, Light1-3 toward hover tints;
         derived from AccentBrush (10/20/30% blends). -->
    <Color x:Key="SystemAccentColor">#88c0d0</Color>
    <Color x:Key="SystemAccentColorDark1">#7aadbb</Color>
    <Color x:Key="SystemAccentColorDark2">#6d9aa6</Color>
    <Color x:Key="SystemAccentColorDark3">#5f8692</Color>
    <Color x:Key="SystemAccentColorLight1">#94c6d5</Color>
    <Color x:Key="SystemAccentColorLight2">#a0cdd9</Color>
    <Color x:Key="SystemAccentColorLight3">#acd3de</Color>

    <!-- Fluent input-state overrides (audit §04): keep the input background on hover/focus
         and use the accent border instead of Fluent's near-black focused background. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#242933" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#242933" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#4c566a" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#88c0d0" />

    <SolidColorBrush x:Key="MethodGetBrush" Color="#a3be8c" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#ebcb8b" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#81a1c1" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#b48ead" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#bf616a" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#8fbcbb" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#6c7689" />

    <!-- Status / semantic — Nord Aurora green/yellow/red + frost blue info + soft tints. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#a3be8c" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#ebcb8b" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#bf616a" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#81a1c1" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#26a3be8c" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#26ebcb8b" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#26bf616a" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#2681a1c1" />

    <SolidColorBrush x:Key="CodeBgBrush" Color="#242933" />

    <!-- Syntax highlighting — Nord family. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#6c7689" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#81a1c1" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#88c0d0" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#a3be8c" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#a3be8c" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#ebcb8b" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#b48ead" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#8fbcbb" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#ebcb8b" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#9aa5b7" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#5288c0d0" />

    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
