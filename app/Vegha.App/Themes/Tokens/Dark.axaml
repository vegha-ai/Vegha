<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Default Dark variant — original palette. -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Bg0Brush" Color="#0b0d10" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#111418" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#161a1f" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#1c2127" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#232930" />
    <SolidColorBrush x:Key="BgInputBrush" Color="#0e1115" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#161a1f" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#0e1115" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style). Dark variants keep
         their existing look: deepest tone (Bg0) frames the title bar; side/activity/header/
         tab/status share the Bg2 mid-surface, above the editor (Bg1) and below cards. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#0b0d10" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#161a1f" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#161a1f" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#161a1f" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#161a1f" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#161a1f" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Border0Brush" Color="#1f2429" />
    <SolidColorBrush x:Key="Border1Brush" Color="#262c33" />
    <SolidColorBrush x:Key="Border2Brush" Color="#323942" />

    <!-- Text -->
    <SolidColorBrush x:Key="Text0Brush" Color="#e6e9ef" />
    <SolidColorBrush x:Key="Text1Brush" Color="#b3b9c4" />
    <SolidColorBrush x:Key="Text2Brush" Color="#7a8290" />
    <SolidColorBrush x:Key="Text3Brush" Color="#525a67" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#0b0d10" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3b82f6" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2563eb" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#1F3b82f6" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#383b82f6" />

    <!-- Fluent SystemAccentColor override — checked marks, toggle switches, sliders,
         focus rings and selection tint with the theme accent instead of Fluent's default
         system blue. Dark1-3 step toward pressed shades, Light1-3 toward hover tints;
         derived from AccentBrush (10/20/30% blends). -->
    <Color x:Key="SystemAccentColor">#3b82f6</Color>
    <Color x:Key="SystemAccentColorDark1">#3575dd</Color>
    <Color x:Key="SystemAccentColorDark2">#2f68c5</Color>
    <Color x:Key="SystemAccentColorDark3">#295bac</Color>
    <Color x:Key="SystemAccentColorLight1">#4f8ef7</Color>
    <Color x:Key="SystemAccentColorLight2">#629bf8</Color>
    <Color x:Key="SystemAccentColorLight3">#76a8f9</Color>

    <!-- Fluent input-state overrides (audit §04 — "focused field renders pure #000").
         These are the resource keys Fluent's TextBox / AutoCompleteBox ControlTheme reads
         for its :pointerover / :focus visuals; overriding them per-theme keeps the input
         background and signals focus with the accent border (never Fluent's near-black
         focused background + system-blue border). Keep in sync with BgInput/Border2/Accent. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0e1115" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#0e1115" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#323942" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#3b82f6" />

    <!-- Method colors -->
    <SolidColorBrush x:Key="MethodGetBrush" Color="#16a34a" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#ca8a04" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#2563eb" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#7c3aed" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#dc2626" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#0891b2" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#475569" />

    <!-- Status / semantic — deliberately distinct from the method hues so "verb"
         (GET green) never collides with "outcome" (2xx success). Solid + soft pair
         per role; soft = ~15% alpha tint of the solid for fills/banners. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#1f9d57" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#d08700" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#dc3a3a" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#2f6df0" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#261f9d57" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#26d08700" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#26dc3a3a" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#262f6df0" />

    <!-- Code background -->
    <SolidColorBrush x:Key="CodeBgBrush" Color="#0a0c0f" />

    <!-- Syntax highlighting — VS Code Dark+ palette. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#6A9955" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#569CD6" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#9CDCFE" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#CE9178" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#CE9178" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#B5CEA8" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#C586C0" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#569CD6" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#DCDCAA" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#D4D4D4" />

    <!-- Selection -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#523b82f6" />

    <!-- Mac chrome traffic lights -->
    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
