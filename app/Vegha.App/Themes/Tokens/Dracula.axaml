<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dracula — official Dracula palette. Deep navy surfaces, purple accent. -->

    <SolidColorBrush x:Key="Bg0Brush" Color="#1b1c25" />
    <SolidColorBrush x:Key="Bg1Brush" Color="#282a36" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#343746" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#3d404f" />
    <SolidColorBrush x:Key="Bg4Brush" Color="#44475a" />
    <SolidColorBrush x:Key="BgInputBrush" Color="#1b1c25" />
    <SolidColorBrush x:Key="BgTabActiveBrush" Color="#343746" />
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="#1b1c25" />

    <!-- Chrome surfaces — one tone per window region (VSCode-style). Preserves the current
         Dracula look: deepest navy (#1b1c25) frames the title bar; side/activity/header/tab/
         status share the #343746 mid-surface, above the editor (Bg1) and below cards. -->
    <SolidColorBrush x:Key="ChromeTitleBarBrush" Color="#1b1c25" />
    <SolidColorBrush x:Key="ChromeActivityBarBrush" Color="#343746" />
    <SolidColorBrush x:Key="ChromeSideBarBrush" Color="#343746" />
    <SolidColorBrush x:Key="ChromeHeaderBarBrush" Color="#343746" />
    <SolidColorBrush x:Key="ChromeTabBarBrush" Color="#343746" />
    <SolidColorBrush x:Key="ChromeStatusBarBrush" Color="#343746" />

    <SolidColorBrush x:Key="Border0Brush" Color="#343746" />
    <SolidColorBrush x:Key="Border1Brush" Color="#44475a" />
    <SolidColorBrush x:Key="Border2Brush" Color="#5c5f72" />

    <SolidColorBrush x:Key="Text0Brush" Color="#f8f8f2" />
    <SolidColorBrush x:Key="Text1Brush" Color="#dadbe8" />
    <SolidColorBrush x:Key="Text2Brush" Color="#a0a3b3" />
    <SolidColorBrush x:Key="Text3Brush" Color="#6272a4" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#282a36" />

    <SolidColorBrush x:Key="AccentBrush" Color="#bd93f9" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#a87ff5" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#22bd93f9" />
    <SolidColorBrush x:Key="AccentSoftStrongBrush" Color="#3abd93f9" />

    <!-- Fluent input-state overrides (audit §04): keep the input background on hover/focus
         and use the accent border instead of Fluent's near-black focused background. -->
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#1b1c25" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#1b1c25" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#5c5f72" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#bd93f9" />

    <SolidColorBrush x:Key="MethodGetBrush" Color="#50fa7b" />
    <SolidColorBrush x:Key="MethodPostBrush" Color="#f1fa8c" />
    <SolidColorBrush x:Key="MethodPutBrush" Color="#8be9fd" />
    <SolidColorBrush x:Key="MethodPatchBrush" Color="#bd93f9" />
    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#ff5555" />
    <SolidColorBrush x:Key="MethodHeadBrush" Color="#8be9fd" />
    <SolidColorBrush x:Key="MethodOptionsBrush" Color="#6272a4" />

    <!-- Status / semantic — Dracula green/orange/red + cyan info + soft tints. -->
    <SolidColorBrush x:Key="StatusOkBrush" Color="#50fa7b" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#ffb86c" />
    <SolidColorBrush x:Key="StatusErrBrush" Color="#ff5555" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#8be9fd" />
    <SolidColorBrush x:Key="StatusOkSoftBrush" Color="#2650fa7b" />
    <SolidColorBrush x:Key="StatusWarnSoftBrush" Color="#26ffb86c" />
    <SolidColorBrush x:Key="StatusErrSoftBrush" Color="#26ff5555" />
    <SolidColorBrush x:Key="StatusInfoSoftBrush" Color="#268be9fd" />

    <SolidColorBrush x:Key="CodeBgBrush" Color="#1b1c25" />

    <!-- Syntax highlighting — Dracula family. Consumed by EditorSyntaxTheme. -->
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#6272a4" />
    <SolidColorBrush x:Key="CodeTagBrush" Color="#8be9fd" />
    <SolidColorBrush x:Key="CodeAttrBrush" Color="#bd93f9" />
    <SolidColorBrush x:Key="CodeAttrValueBrush" Color="#50fa7b" />
    <SolidColorBrush x:Key="CodeStringBrush" Color="#50fa7b" />
    <SolidColorBrush x:Key="CodeNumberBrush" Color="#f1fa8c" />
    <SolidColorBrush x:Key="CodeKeywordBrush" Color="#bd93f9" />
    <SolidColorBrush x:Key="CodeBoolBrush" Color="#8be9fd" />
    <SolidColorBrush x:Key="CodeFunctionBrush" Color="#f1fa8c" />
    <SolidColorBrush x:Key="CodePunctBrush" Color="#a0a3b3" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#52bd93f9" />

    <SolidColorBrush x:Key="MacRedBrush" Color="#ff5f57" />
    <SolidColorBrush x:Key="MacAmberBrush" Color="#ffbd2e" />
    <SolidColorBrush x:Key="MacGreenBrush" Color="#28c840" />
</ResourceDictionary>
