<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="700"
             x:Class="Vegha.App.Controls.Shell.InfoPanel">
    <DockPanel Background="{DynamicResource ChromeSideBarBrush}">
        <Border DockPanel.Dock="Top" Padding="10,8" Height="34"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,0,0,1">
            <TextBlock Name="HeaderText" Text="SECTION"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}"
                       VerticalAlignment="Center" />
        </Border>
        <ScrollViewer>
            <StackPanel Margin="14,12" Spacing="10">
                <TextBlock Name="TitleText"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text0Brush}" />
                <TextBlock Name="DescriptionText"
                           FontSize="11"
                           Foreground="{DynamicResource Text2Brush}"
                           TextWrapping="Wrap"
                           LineHeight="16" />
                <ItemsControl Name="FeaturesList" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid ColumnDefinitions="14,*" Margin="0,3,0,0">
                                <TextBlock Grid.Column="0"
                                           Text="•"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text3Brush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text1Brush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Name="StatusText"
                           FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource Text3Brush}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
