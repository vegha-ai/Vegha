<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels.Settings"
             xmlns:icons="using:Vegha.App.Controls.Icons"
             xmlns:conv="using:Vegha.App.Controls.Converters"
             mc:Ignorable="d" d:DesignWidth="780"
             x:Class="Vegha.App.Controls.Settings.Pages.AppearancePage"
             x:DataType="vm:AppearanceSettingsViewModel"
             x:Name="Root">
    <StackPanel Spacing="28" MaxWidth="820">
        <!-- Page heading -->
        <TextBlock Text="Appearance"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Text0Brush}" />

        <!-- Mode toggle (Light / Dark / System) -->
        <StackPanel Spacing="10">
            <TextBlock Text="APPEARANCE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />
            <StackPanel Orientation="Horizontal" Spacing="10">
                <RadioButton GroupName="ThemeMode" Tag="light" Click="OnModeClick"
                             IsChecked="{Binding ThemeMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=light, Mode=OneWay}"
                             Padding="14,8" MinWidth="92">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:Icon Kind="Sun" Size="14" Foreground="{DynamicResource Text1Brush}" />
                        <TextBlock Text="Light" VerticalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton GroupName="ThemeMode" Tag="dark" Click="OnModeClick"
                             IsChecked="{Binding ThemeMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=dark, Mode=OneWay}"
                             Padding="14,8" MinWidth="92">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:Icon Kind="Moon" Size="14" Foreground="{DynamicResource Text1Brush}" />
                        <TextBlock Text="Dark" VerticalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton GroupName="ThemeMode" Tag="system" Click="OnModeClick"
                             IsChecked="{Binding ThemeMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=system, Mode=OneWay}"
                             Content="System"
                             Padding="14,8" MinWidth="92" />
            </StackPanel>
        </StackPanel>

        <!-- Variant grid — items come from FilteredVariants so only the
             variants matching the current ThemeMode (light vs dark) are shown.
             Each card renders its OWN palette swatches (background block,
             surface block, text bar, accent bar) so the user can compare
             themes side-by-side without having to apply them first. The
             currently-selected variant gets an accent ring + checkmark. -->
        <StackPanel Spacing="10">
            <TextBlock Text="THEME VARIANT"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />
            <ItemsControl ItemsSource="{Binding FilteredVariants}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="200" ItemHeight="140" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ThemeVariantEntry">
                        <Button Click="OnVariantClick"
                                Tag="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0" Margin="0,0,12,12"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                            <Grid>
                                <!-- Card: paints its OWN background color (the variant's Bg1
                                     token) so the preview doesn't lie about the theme's mood.
                                     Inner Border supplies the surface block + sample bars. -->
                                <Border CornerRadius="6"
                                        BorderThickness="2"
                                        Background="{Binding Background, Converter={StaticResource HexToBrushConverter}}"
                                        Padding="12">
                                    <!-- BorderBrush flips to AccentBrush when this entry matches
                                         the active SelectedVariantId on the parent VM — purely
                                         decorative ring; Transparent when not selected so the
                                         card edges line up flush. -->
                                    <Border.BorderBrush>
                                        <MultiBinding Converter="{x:Static conv:EqualToBrushConverter.Instance}">
                                            <Binding Path="Id" />
                                            <Binding Path="DataContext.SelectedVariantId"
                                                     ElementName="Root" />
                                        </MultiBinding>
                                    </Border.BorderBrush>
                                    <Grid RowDefinitions="*,Auto">
                                        <!-- Preview surface — Bg2 token block carrying the
                                             theme's "text bar" + "accent bar" inside it. -->
                                        <Border Grid.Row="0"
                                                CornerRadius="4"
                                                Background="{Binding Surface, Converter={StaticResource HexToBrushConverter}}"
                                                Padding="10">
                                            <StackPanel Spacing="6" VerticalAlignment="Center">
                                                <Border Height="6" CornerRadius="2" Width="120"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding Text, Converter={StaticResource HexToBrushConverter}}" />
                                                <Border Height="6" CornerRadius="2" Width="80"
                                                        HorizontalAlignment="Left" Opacity="0.55"
                                                        Background="{Binding Text, Converter={StaticResource HexToBrushConverter}}" />
                                                <Border Height="6" CornerRadius="2" Width="48"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding Accent, Converter={StaticResource HexToBrushConverter}}" />
                                            </StackPanel>
                                        </Border>
                                        <!-- Label uses the variant's own text color over the
                                             variant's background so the card name reads with the
                                             same contrast the running app would have. -->
                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="2,10,2,0">
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{Binding Text, Converter={StaticResource HexToBrushConverter}}" />
                                            <!-- Selected check — visible only when this is the
                                                 active variant for the current mode. -->
                                            <Border Grid.Column="1" CornerRadius="8" Width="16" Height="16"
                                                    Background="{Binding Accent, Converter={StaticResource HexToBrushConverter}}">
                                                <Border.IsVisible>
                                                    <MultiBinding Converter="{x:Static conv:EqualMultiConverter.Instance}">
                                                        <Binding Path="Id" />
                                                        <Binding Path="DataContext.SelectedVariantId"
                                                                 ElementName="Root" />
                                                    </MultiBinding>
                                                </Border.IsVisible>
                                                <TextBlock Text="✓" FontSize="10" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Interface zoom. IsSnapToTickEnabled + TickFrequency=0.1 makes the
             slider step at exactly 10% increments (80, 90, 100, ..., 200). -->
        <StackPanel Spacing="6">
            <TextBlock Text="INTERFACE ZOOM"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />
            <TextBlock Text="Scale the entire UI. Also available as Ctrl+= / Ctrl+- / Ctrl+0."
                       FontSize="11" Foreground="{DynamicResource Text2Brush}" />
            <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                <Slider Grid.Column="0"
                        Minimum="0.8" Maximum="2.0"
                        SmallChange="0.1" LargeChange="0.1"
                        TickFrequency="0.1"
                        IsSnapToTickEnabled="True"
                        TickPlacement="BottomRight"
                        Value="{Binding InterfaceZoom, Mode=TwoWay}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding InterfaceZoom, StringFormat='{}{0:P0}'}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text1Brush}"
                           Margin="14,0,0,0" MinWidth="48" />
            </Grid>
        </StackPanel>

        <!-- UI font (chrome) — applies to labels/menus -->
        <StackPanel Spacing="10">
            <TextBlock Text="UI FONT"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />
            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mono font family"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text1Brush}" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FontFamily, Mode=TwoWay}"
                         MaxWidth="280" HorizontalAlignment="Left"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}"
                         Padding="8,6" CornerRadius="3" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Editor font size"
                           VerticalAlignment="Center" Margin="0,10,0,0"
                           Foreground="{DynamicResource Text1Brush}" />
                <NumericUpDown Grid.Row="1" Grid.Column="1"
                               Value="{Binding FontSize, Mode=TwoWay}"
                               Minimum="8" Maximum="24" Increment="1"
                               Margin="0,10,0,0" />
            </Grid>
        </StackPanel>
    </StackPanel>
</UserControl>
