<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels.Settings"
             mc:Ignorable="d" d:DesignWidth="780"
             x:Class="Vegha.App.Controls.Settings.Pages.EditorPage"
             x:DataType="vm:EditorSettingsViewModel">
    <StackPanel Spacing="28" MaxWidth="820">
        <TextBlock Text="Editor"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Text0Brush}" />

        <StackPanel Spacing="14">
            <TextBlock Text="FONT"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />
            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Font family"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text1Brush}" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding FontFamily, Mode=TwoWay}"
                         MaxWidth="280" HorizontalAlignment="Left"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}"
                         Padding="8,6" CornerRadius="3" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Font size"
                           VerticalAlignment="Center" Margin="0,10,0,0"
                           Foreground="{DynamicResource Text1Brush}" />
                <NumericUpDown Grid.Row="1" Grid.Column="1"
                               Value="{Binding FontSize, Mode=TwoWay}"
                               Minimum="8" Maximum="24" Increment="1"
                               Margin="0,10,0,0" />
            </Grid>
        </StackPanel>

        <StackPanel Spacing="14">
            <TextBlock Text="EDITING"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />
            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tab size"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text1Brush}" />
                <NumericUpDown Grid.Row="0" Grid.Column="1"
                               Value="{Binding TabSize, Mode=TwoWay}"
                               Minimum="1" Maximum="8" Increment="1" />

                <CheckBox Grid.Row="1" Grid.Column="1"
                          Content="Word wrap"
                          IsChecked="{Binding WordWrap, Mode=TwoWay}"
                          Margin="0,12,0,0" />

                <CheckBox Grid.Row="2" Grid.Column="1"
                          Content="Show line numbers"
                          IsChecked="{Binding ShowLineNumbers, Mode=TwoWay}"
                          Margin="0,6,0,0" />
            </Grid>
        </StackPanel>
    </StackPanel>
</UserControl>
