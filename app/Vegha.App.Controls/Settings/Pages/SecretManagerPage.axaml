<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels.Settings"
             xmlns:conv="using:Vegha.App.Controls.Converters"
             mc:Ignorable="d" d:DesignWidth="780"
             x:Class="Vegha.App.Controls.Settings.Pages.SecretManagerPage"
             x:DataType="vm:SecretManagerSettingsViewModel">
    <UserControl.Resources>
        <conv:BoolToPasswordCharConverter x:Key="BoolToPasswordCharConverter" />
    </UserControl.Resources>
    <StackPanel Spacing="22" MaxWidth="820">
        <StackPanel Spacing="6">
            <TextBlock Text="Secret Manager"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text0Brush}" />
            <TextBlock TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource Text2Brush}"
                       Text="Connect an external secret manager so environment variables can reference secrets with a secret://provider/path#field URI instead of storing values locally. Credentials entered here are encrypted on this machine." />
        </StackPanel>

        <!-- Configured providers -->
        <StackPanel Spacing="10">
            <TextBlock Text="CONFIGURED PROVIDERS"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />

            <TextBlock IsVisible="{Binding !HasProviders}"
                       Text="No providers configured yet. Add one below."
                       FontSize="12" FontStyle="Italic"
                       Foreground="{DynamicResource Text3Brush}" />

            <ItemsControl ItemsSource="{Binding Providers}" IsVisible="{Binding HasProviders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SecretProviderRow">
                        <Border Background="{DynamicResource Bg2Brush}"
                                BorderBrush="{DynamicResource Border0Brush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,10" Margin="0,0,0,8">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Text0Brush}" />
                                            <Border Background="{DynamicResource Bg3Brush}"
                                                    CornerRadius="3" Padding="6,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TypeLabel}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource Text2Brush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Detail}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Text2Brush}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Remove"
                                            Command="{Binding $parent[ItemsControl].((vm:SecretManagerSettingsViewModel)DataContext).RemoveProviderCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource Bg3Brush}"
                                            BorderBrush="{DynamicResource Border1Brush}"
                                            Foreground="{DynamicResource Text0Brush}"
                                            Padding="14,6" CornerRadius="3"
                                            VerticalAlignment="Center" />
                                </Grid>

                                <!-- Test: fetch one secret to verify auth + connectivity. -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding TestSecretName, Mode=TwoWay}"
                                             Watermark="{Binding TestFieldHint}"
                                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                                             Background="{DynamicResource BgInputBrush}"
                                             BorderBrush="{DynamicResource Border1Brush}"
                                             Foreground="{DynamicResource Text0Brush}"
                                             Padding="8,5" CornerRadius="3" />
                                    <Button Grid.Column="1" Content="Test"
                                            Command="{Binding TestCommand}"
                                            IsEnabled="{Binding !IsTesting}"
                                            Background="{DynamicResource Bg3Brush}"
                                            BorderBrush="{DynamicResource Border1Brush}"
                                            Foreground="{DynamicResource Text0Brush}"
                                            Padding="16,5" CornerRadius="3" />
                                </Grid>
                                <TextBlock Text="{Binding TestResult}"
                                           IsVisible="{Binding TestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Text1Brush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Add provider -->
        <StackPanel Spacing="12">
            <TextBlock Text="ADD PROVIDER"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text2Brush}" />

            <Grid ColumnDefinitions="160,*" ColumnSpacing="12" RowSpacing="12"
                  RowDefinitions="Auto,Auto">

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Provider type"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text1Brush}" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding ProviderTypes}"
                          SelectedItem="{Binding SelectedProviderType, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SecretProviderTypeOption">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Name"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text1Brush}" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding NewProviderName, Mode=TwoWay}"
                         Watermark="e.g. prod"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}"
                         Padding="8,6" CornerRadius="3" />
            </Grid>

            <!-- Provider-type-specific fields (rebuilt when the type changes). -->
            <ItemsControl ItemsSource="{Binding NewFields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProviderFieldInput">
                        <Grid ColumnDefinitions="160,*" ColumnSpacing="12" Margin="0,0,0,12">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="3"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{DynamicResource Text1Brush}" />
                                <TextBlock Text="*" IsVisible="{Binding Required}"
                                           Foreground="{DynamicResource StatusErrBrush}" />
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Text="{Binding Value, Mode=TwoWay}"
                                     Watermark="{Binding Example}"
                                     PasswordChar="{Binding ShowPlain, Converter={StaticResource BoolToPasswordCharConverter}}"
                                     FontFamily="{StaticResource MonoFont}"
                                     Background="{DynamicResource BgInputBrush}"
                                     BorderBrush="{DynamicResource Border1Brush}"
                                     Foreground="{DynamicResource Text0Brush}"
                                     Padding="8,6" CornerRadius="3" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Add provider"
                    Command="{Binding AddProviderCommand}"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0"
                    Padding="18,8" CornerRadius="3" />
        </StackPanel>

        <!-- Status -->
        <TextBlock Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="12"
                   Foreground="{DynamicResource Text1Brush}" />

        <!-- Authentication note -->
        <Border Background="{DynamicResource Bg3Brush}" Padding="14" CornerRadius="6">
            <StackPanel Spacing="6">
                <TextBlock Text="Authentication" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text1Brush}" />
                <TextBlock TextWrapping="Wrap" FontSize="11"
                           Foreground="{DynamicResource Text2Brush}"
                           Text="Azure Key Vault uses Entra ID OAuth 2.0. Supply the tenant, client ID and client secret of an app registration that holds a Key Vault access policy or RBAC role — or leave them blank to use Azure CLI / managed identity." />
                <TextBlock TextWrapping="Wrap" FontSize="11"
                           Foreground="{DynamicResource Text2Brush}"
                           Text="AWS Secrets Manager signs requests with IAM access keys (not OAuth). Supply an access key ID and secret access key — add a session token for temporary STS/SSO credentials — or leave them blank to use the AWS default credential chain." />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
