<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels.Settings"
             mc:Ignorable="d" d:DesignWidth="780"
             x:Class="Vegha.App.Controls.Settings.Pages.ShortcutsPage"
             x:DataType="vm:ShortcutsSettingsViewModel">
    <StackPanel Spacing="20" MaxWidth="820">
        <TextBlock Text="Shortcuts"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Text0Brush}" />
        <TextBlock Text="Read-only — keyboard shortcuts are not yet rebindable."
                   FontSize="11" Foreground="{DynamicResource Text2Brush}" />

        <Border Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="1" CornerRadius="6">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ShortcutRow">
                        <Border Padding="16,10"
                                BorderBrush="{DynamicResource Border0Brush}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="140,*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Category}"
                                           Foreground="{DynamicResource Text2Brush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding Action}"
                                           Foreground="{DynamicResource Text0Brush}" />
                                <Border Grid.Column="2"
                                        Background="{DynamicResource Bg3Brush}"
                                        BorderBrush="{DynamicResource Border1Brush}"
                                        BorderThickness="1" CornerRadius="3"
                                        Padding="8,3">
                                    <TextBlock Text="{Binding Gesture}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text1Brush}" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </StackPanel>
</UserControl>
