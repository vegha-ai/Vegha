<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels"
             xmlns:ws="using:Vegha.App.Controls.Workspace"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="240"
             x:Class="Vegha.App.Controls.Workspace.KvEditor"
             x:Name="Root">
    <!-- DockPanel root used to host the body region (rows ScrollViewer + bulk-edit TextBox)
         as siblings of the docked Top/Bottom borders — but DockPanel's LastChildFill rule
         only gives the fill slot to ONE child. With both the ScrollViewer AND the bulk-edit
         TextBox present (alternating via IsVisible), only the textually-last child got the
         remaining width, and the other collapsed to its content. That's why headers rows
         rendered at ~300px in a 1200px pane.
         Fix: keep DockPanel for the Top/Bottom borders, but put the body region inside a
         single Grid cell so both possible bodies (rows vs bulk-edit) share the same
         "fill" slot via overlapping Grid.Row=0. -->
    <DockPanel Background="{DynamicResource Bg2Brush}">
        <!-- Footer with Add-row + Bulk-edit toggle -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Classes="tertiary"
                        Content="+ Add row"
                        Command="{Binding #Root.AddCommand}"
                        IsVisible="{Binding #Root.IsBulkMode, Converter={x:Static BoolConverters.Not}}" />
                <!-- Bulk-edit toggle. Bruno parity — flips between table and a textarea
                     where the user pastes/edits `Key: Value` pairs in bulk. -->
                <ToggleButton Grid.Column="2"
                              Content="Bulk edit"
                              IsChecked="{Binding #Root.IsBulkMode, Mode=TwoWay}"
                              FontSize="11"
                              Padding="10,4"
                              ToolTip.Tip="Toggle between the row table and a textarea. Lines accept either &quot;Key: Value&quot; or &quot;key=value&quot;. Prefix with ~ to disable, # for comments." />
            </Grid>
        </Border>

        <!-- Header row (only when in table mode) -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding #Root.IsBulkMode, Converter={x:Static BoolConverters.Not}}"
                Background="{DynamicResource Bg3Brush}"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="32,1*,1*,32" Height="26">
                <TextBlock Grid.Column="1" Text="KEY" Margin="8,0,0,0"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text2Brush}"
                           VerticalAlignment="Center"
                           LetterSpacing="1" />
                <TextBlock Grid.Column="2" Text="VALUE" Margin="8,0,0,0"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text2Brush}"
                           VerticalAlignment="Center"
                           LetterSpacing="1" />
            </Grid>
        </Border>

        <!-- Body region: rows table OR bulk-edit textarea, both inside a single Grid cell
             so they share the DockPanel's "fill" slot. Putting them as sibling DockPanel
             children meant only the textually-last child got the fill slot, and the other
             collapsed to its content width — the headers-row-squish bug. With both in one
             Grid cell, the cell stretches to fill the DockPanel, and IsVisible toggles
             which of the two is painted. -->
        <Grid>
            <!-- Rows (table mode) — delegates to the shared KvTableRow UserControl so styling
                 stays aligned with OAuth2 Additional Parameters / multipart / form-urlencoded
                 body rows. -->
            <ScrollViewer IsVisible="{Binding #Root.IsBulkMode, Converter={x:Static BoolConverters.Not}}"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding #Root.ItemsSource}"
                              HorizontalAlignment="Stretch">
                    <!-- ItemContainerTheme is the canonical Avalonia 11 way to set properties
                         on the ContentPresenter that wraps each item. Both HorizontalAlignment
                         and HorizontalContentAlignment are required: the former makes the
                         presenter fill the StackPanel slot, the latter makes the inner
                         KvTableRow honor that width instead of collapsing to its content. -->
                    <ItemsControl.ItemContainerTheme>
                        <ControlTheme TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </ControlTheme>
                    </ItemsControl.ItemContainerTheme>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:KvEntry">
                            <ws:KvTableRow Variables="{Binding #Root.Variables}"
                                           HeaderSuggestions="{Binding #Root.RowHeaderSuggestions}"
                                           KeyWatermark="{Binding #Root.RowKeyWatermark}"
                                           RemoveCommand="{Binding #Root.RemoveCommand}"
                                           HorizontalAlignment="Stretch" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Bulk edit (textarea) — visible only when IsBulkMode=true. -->
            <TextBox IsVisible="{Binding #Root.IsBulkMode}"
                     Text="{Binding #Root.BulkText, Mode=TwoWay}"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="12"
                     Background="{DynamicResource Bg2Brush}"
                     Foreground="{DynamicResource Text0Brush}"
                     BorderThickness="0"
                     Padding="12,8"
                     Watermark="Key: Value&#x0A;Authorization: Bearer {{token}}&#x0A;~Disabled-Header: foo&#x0A;# Comment line" />
        </Grid>
    </DockPanel>
</UserControl>
