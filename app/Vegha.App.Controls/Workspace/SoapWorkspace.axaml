<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels"
             xmlns:wsdl="using:Vegha.Integrations.Wsdl"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="640"
             x:Class="Vegha.App.Controls.Workspace.SoapWorkspace"
             x:DataType="vm:SoapWorkspaceViewModel">
    <DockPanel Background="{DynamicResource Bg2Brush}">

        <!-- Top: WSDL + endpoint + send -->
        <Border DockPanel.Dock="Top" Padding="12,10"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="WSDL"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text2Brush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding WsdlSource}"
                             Watermark="https://example.com/service.wsdl   |   /local/path.wsdl   |   paste raw &lt;definitions&gt;…"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             Background="{DynamicResource BgInputBrush}"
                             BorderBrush="{DynamicResource Border1Brush}"
                             Foreground="{DynamicResource Text0Brush}"
                             Padding="8,6" CornerRadius="3" />
                    <Button Grid.Column="2"
                            Command="{Binding LoadWsdlCommand}"
                            Content="Load"
                            Background="{DynamicResource Bg3Brush}"
                            Foreground="{DynamicResource Text0Brush}"
                            Padding="14,6" Margin="8,0,0,0" />
                </Grid>

                <Grid ColumnDefinitions="160,*,Auto,Auto">
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Operations}"
                              SelectedItem="{Binding SelectedOperation}"
                              PlaceholderText="Operation"
                              Background="{DynamicResource BgInputBrush}"
                              Foreground="{DynamicResource Text0Brush}"
                              Padding="8,4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="wsdl:WsdlOperation">
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Grid.Column="1"
                             Text="{Binding EndpointUrl}"
                             Watermark="Endpoint URL"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             Background="{DynamicResource BgInputBrush}"
                             BorderBrush="{DynamicResource Border1Brush}"
                             Foreground="{DynamicResource Text0Brush}"
                             Padding="8,6" CornerRadius="3"
                             Margin="8,0,0,0" />
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding UseSoap12}"
                              Content="SOAP 1.2"
                              Foreground="{DynamicResource Text0Brush}"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center" />
                    <Button Grid.Column="3"
                            Command="{Binding SendCommand}"
                            Content="Send"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            Padding="18,6" Margin="8,0,0,0" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="SOAPAction"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text2Brush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SoapAction}"
                             Watermark="(empty for none)"
                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                             Background="{DynamicResource BgInputBrush}"
                             BorderBrush="{DynamicResource Border1Brush}"
                             Foreground="{DynamicResource Text0Brush}"
                             Padding="8,4" CornerRadius="3" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Status / footer -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Bg3Brush}"
                Padding="12,4"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11"
                       Foreground="{DynamicResource Text2Brush}" />
        </Border>

        <!-- Body | Response -->
        <Grid ColumnDefinitions="*,*">
            <DockPanel Grid.Column="0" Margin="12">
                <TextBlock DockPanel.Dock="Top" Text="Request body (inner XML — wrapped in &lt;Envelope&gt;&lt;Body&gt;…)"
                           FontSize="11"
                           Foreground="{DynamicResource Text2Brush}"
                           Margin="0,0,0,6" />
                <TextBox x:Name="BodyEditor"
                         Text="{Binding BodyXml}"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}"
                         Padding="8,6" CornerRadius="3" />
            </DockPanel>

            <DockPanel Grid.Column="1" Margin="0,12,12,12">
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Response (Body element only)"
                               FontSize="11"
                               Foreground="{DynamicResource Text2Brush}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{DynamicResource Text0Brush}">
                            <Run Text="{Binding ResponseStatusCode}" />
                            <Run Text=" · " />
                            <Run Text="{Binding ResponseElapsedMs}" />
                            <Run Text=" ms" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding ResponseBodyOnly}"
                                         FontFamily="{StaticResource MonoFont}"
                                         FontSize="11"
                                         TextWrapping="Wrap"
                                         Foreground="{DynamicResource Text0Brush}" />
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
