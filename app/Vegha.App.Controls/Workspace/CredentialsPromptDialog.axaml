<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="440" d:DesignHeight="260"
        x:Class="Vegha.App.Controls.Workspace.CredentialsPromptDialog"
        Title="Git credentials"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="20">
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto" Margin="0,16,0,0">
            <Border Grid.Column="0" />
            <Button Grid.Column="1" Content="Cancel" Click="OnCancel_Click"
                    Background="Transparent"
                    BorderBrush="{DynamicResource Border1Brush}"
                    BorderThickness="1"
                    Foreground="{DynamicResource Text0Brush}"
                    Padding="14,6" Margin="0,0,8,0"
                    CornerRadius="4" />
            <Button Grid.Column="2" Content="Sign in" Click="OnOk_Click"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="18,6"
                    CornerRadius="4"
                    FontWeight="SemiBold" />
        </Grid>
        <StackPanel Spacing="10">
            <TextBlock Text="The Git operation needs credentials to continue."
                       FontSize="12" Foreground="{DynamicResource Text1Brush}" />
            <StackPanel Spacing="3">
                <TextBlock Text="Host" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text2Brush}" />
                <TextBlock x:Name="HostLabel" FontSize="12"
                           Foreground="{DynamicResource Text0Brush}"
                           FontFamily="{StaticResource MonoFont}" />
            </StackPanel>
            <StackPanel Spacing="3">
                <TextBlock Text="Username" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text2Brush}" />
                <TextBox x:Name="UserBox"
                         FontSize="13"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}"
                         Padding="8,6" />
            </StackPanel>
            <StackPanel Spacing="3">
                <TextBlock Text="Personal access token / password"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text2Brush}" />
                <TextBox x:Name="SecretBox"
                         PasswordChar="•"
                         FontSize="13"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}"
                         Padding="8,6" />
            </StackPanel>
            <CheckBox x:Name="RememberBox" Content="Remember (store in vault)"
                      FontSize="11"
                      Foreground="{DynamicResource Text1Brush}" />
        </StackPanel>
    </DockPanel>
</Window>
