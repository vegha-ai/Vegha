<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="640"
        x:Class="Vegha.App.Controls.Workspace.HelpDialog"
        Title="Vegha — Help"
        Icon="avares://Vegha.App/Assets/logo.png"
        Width="560" Height="640"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Window.Styles>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.key">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Text0Brush}" />
        </Style>
        <Style Selector="TextBlock.desc">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Styles>

    <!-- Three explicit rows so the ScrollViewer's bottom edge can never overlap
         the footer (the Bottom dock in a DockPanel was bleeding the last card
         underneath the close button band). -->
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Keyboard shortcuts &amp; tips"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text0Brush}" />
                    <TextBlock Text="Quick reference. The full shortcut list lives in Settings → Shortcuts."
                               FontSize="11" Foreground="{DynamicResource Text2Brush}" />
                </StackPanel>
                <Button Grid.Column="1"
                        x:Name="DocsButton"
                        Click="OnDocs_Click"
                        Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource Border1Brush}"
                        Foreground="{DynamicResource Text0Brush}"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Open documentation" FontSize="11" />
                        <TextBlock Text="↗" FontSize="11" Foreground="{DynamicResource AccentBrush}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Body. Edge spacing lives on the inner StackPanel as Margin, NOT on
             the ScrollViewer as Padding. Padding on the ScrollViewer subtracts
             from the scrollable extent so a max-scroll stops short of the
             last card; Margin on the content keeps the extent honest. Same
             fix used in SettingsWindow.axaml. -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="BodyHost" Spacing="20" Margin="24,16" />
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           FontSize="11"
                           Foreground="{DynamicResource Text3Brush}"
                           VerticalAlignment="Center">
                    <Run Text="vegha.ai/docs" />
                    <Run Text=" · " />
                    <Run Text="MIT licensed" />
                </TextBlock>
                <Button Grid.Column="1"
                        Content="Close"
                        Click="OnClose_Click"
                        IsDefault="True"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0"
                        Padding="18,6" CornerRadius="3" FontWeight="SemiBold" />
            </Grid>
        </Border>
    </Grid>
</Window>
