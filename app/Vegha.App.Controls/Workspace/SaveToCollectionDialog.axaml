<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:w="using:Vegha.App.Controls.Workspace"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="540"
        x:Class="Vegha.App.Controls.Workspace.SaveToCollectionDialog"
        Title="Save to collection"
        Width="480" Height="540"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="20">
        <!-- Footer: New Folder (left) · Cancel / Save (right) -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
            <Button Grid.Column="0" Content="New Folder" Click="OnNewFolder_Click"
                    Background="{DynamicResource Bg3Brush}"
                    Foreground="{DynamicResource Text0Brush}"
                    BorderBrush="{DynamicResource Border1Brush}" BorderThickness="1"
                    Padding="12,6" CornerRadius="3" />
            <Button Grid.Column="2" Content="Cancel" Click="OnCancel_Click"
                    Background="Transparent" Foreground="{DynamicResource Text1Brush}"
                    BorderThickness="0" Padding="14,6" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="Save" Click="OnSave_Click" IsDefault="True"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="18,6" CornerRadius="3" FontWeight="SemiBold" />
        </Grid>

        <!-- Request name -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="Request name" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource Text0Brush}" />
            <TextBox Name="NameBox" Watermark="Request name" FontSize="12"
                     Background="{DynamicResource BgInputBrush}"
                     BorderBrush="{DynamicResource Border1Brush}"
                     Foreground="{DynamicResource Text0Brush}"
                     Padding="10,8" CornerRadius="3" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="Save in folder" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource Text0Brush}" Margin="0,0,0,4" />

        <!-- Live destination / validation hint -->
        <TextBlock DockPanel.Dock="Bottom" Name="LocationText" FontSize="11"
                   Foreground="{DynamicResource Text2Brush}" Margin="0,8,0,0" TextWrapping="Wrap" />

        <!-- Folder picker: the active collection's folders (compact style = small chevron,
             hidden for folders with no sub-folders). Leave unselected to save at the root. -->
        <Border BorderBrush="{DynamicResource Border1Brush}" BorderThickness="1" CornerRadius="3"
                Background="{DynamicResource BgInputBrush}">
            <TreeView Name="FolderTree" Classes="compact"
                      SelectionChanged="OnSelectionChanged"
                      Background="Transparent" Padding="4,4,8,4">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="w:SaveTargetNode">
                        <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Text1Brush}" />
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </DockPanel>
</Window>
