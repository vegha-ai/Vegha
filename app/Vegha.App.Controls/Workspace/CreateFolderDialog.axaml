<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="180"
        x:Class="Vegha.App.Controls.Workspace.CreateFolderDialog"
        Title="New Folder"
        Width="420" Height="200"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="20">
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto" Margin="0,16,0,0">
            <Button Grid.Column="1" Content="Cancel" Click="OnCancel_Click"
                    Background="Transparent" Foreground="{DynamicResource Text1Brush}"
                    BorderThickness="0" Padding="14,6" Margin="0,0,8,0" />
            <Button Grid.Column="2" Content="Create" Click="OnCreate_Click"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="18,6" CornerRadius="3"
                    FontWeight="SemiBold" />
        </Grid>

        <StackPanel Spacing="10">
            <TextBlock Text="Folder name" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource Text0Brush}" />
            <TextBox Name="NameBox" Watermark="My Folder"
                     FontSize="12"
                     Background="{DynamicResource BgInputBrush}"
                     BorderBrush="{DynamicResource Border1Brush}"
                     Foreground="{DynamicResource Text0Brush}"
                     Padding="10,8" CornerRadius="3" />
            <TextBlock FontSize="11" Foreground="{DynamicResource Text3Brush}"
                       TextWrapping="Wrap"
                       Text="Invalid filesystem characters are replaced with underscores." />
        </StackPanel>
    </DockPanel>
</Window>
