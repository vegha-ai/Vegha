<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="420"
        x:Class="Vegha.App.Controls.Workspace.AboutDialog"
        Title="About Vegha"
        Icon="avares://Vegha.App/Assets/logo.png"
        Width="460" Height="420"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="28">
        <!-- Footer -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,18,0,0">
            <Button Grid.Column="0"
                    x:Name="CopyVersionButton"
                    Content="Copy version info"
                    Click="OnCopyVersion_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource AccentBrush}"
                    Padding="0,6"
                    HorizontalAlignment="Left"
                    FontSize="11" />
            <Button Grid.Column="1"
                    Content="Close" Click="OnClose_Click"
                    IsDefault="True"
                    Background="{DynamicResource Bg3Brush}"
                    Foreground="{DynamicResource Text0Brush}"
                    Padding="18,6" />
        </Grid>

        <StackPanel Spacing="18" HorizontalAlignment="Center">
            <!-- Logo -->
            <Image Source="avares://Vegha.App/Assets/logo.png"
                   Width="72" Height="72"
                   HorizontalAlignment="Center" />

            <!-- Name + tagline -->
            <StackPanel Spacing="2" HorizontalAlignment="Center">
                <TextBlock Text="Vegha"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text0Brush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Native API testing for Windows and macOS"
                           FontSize="12"
                           Foreground="{DynamicResource Text2Brush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Product info grid -->
            <Border Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource Border0Brush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="16,12">
                <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto,4,Auto,4,Auto,4,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"
                               FontSize="11" Foreground="{DynamicResource Text2Brush}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" x:Name="VersionText"
                               FontSize="11" FontWeight="SemiBold"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{DynamicResource Text0Brush}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Distribution"
                               FontSize="11" Foreground="{DynamicResource Text2Brush}" />
                    <TextBlock Grid.Row="2" Grid.Column="2" x:Name="DistributionText"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text0Brush}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Runtime"
                               FontSize="11" Foreground="{DynamicResource Text2Brush}" />
                    <TextBlock Grid.Row="4" Grid.Column="2" x:Name="RuntimeText"
                               FontSize="11"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{DynamicResource Text1Brush}" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Copyright"
                               FontSize="11" Foreground="{DynamicResource Text2Brush}" />
                    <TextBlock Grid.Row="6" Grid.Column="2" x:Name="CopyrightText"
                               FontSize="11"
                               Foreground="{DynamicResource Text1Brush}" />
                </Grid>
            </Border>

            <!-- Licensing note -->
            <TextBlock Text="MIT licensed. Built with Avalonia."
                       FontSize="11"
                       Foreground="{DynamicResource Text3Brush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </DockPanel>
</Window>
