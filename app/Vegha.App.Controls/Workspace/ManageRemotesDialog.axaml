<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Vegha.App.ViewModels"
        xmlns:icons="using:Vegha.App.Controls.Icons"
        mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="420"
        x:Class="Vegha.App.Controls.Workspace.ManageRemotesDialog"
        x:DataType="vm:GitViewModel"
        Title="Manage Git remotes"
        Width="640" Height="420"
        CanResize="True"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner">
    <Window.Styles>
        <Style Selector="Button.smallAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Foreground" Value="{DynamicResource Text1Brush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="Button.smallAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Bg3Brush}" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="14">
        <!-- Bottom action bar -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
            <Button Grid.Column="0" Content="Add Remote..."
                    Click="OnAdd_Click"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="14,6"
                    HorizontalAlignment="Left"
                    CornerRadius="4" />
            <Button Grid.Column="1" Content="Close"
                    Click="OnClose_Click"
                    IsDefault="True"
                    Background="Transparent"
                    BorderBrush="{DynamicResource Border1Brush}"
                    BorderThickness="1"
                    Foreground="{DynamicResource Text0Brush}"
                    Padding="14,6"
                    CornerRadius="4" />
        </Grid>

        <!-- Top description -->
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,10"
                   Text="Remotes are named pointers to other repositories. Add 'origin' before push/pull, or add additional remotes for forks."
                   FontSize="11" TextWrapping="Wrap"
                   Foreground="{DynamicResource Text2Brush}" />

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   IsVisible="{Binding !Remotes.Count}"
                   Text="No remotes configured yet."
                   FontStyle="Italic" FontSize="11"
                   Foreground="{DynamicResource Text3Brush}"
                   HorizontalAlignment="Center" Margin="0,40,0,0" />

        <!-- Remotes list -->
        <Border BorderBrush="{DynamicResource Border1Brush}" BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding !!Remotes.Count}">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Remotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GitRemoteRow">
                            <Border Padding="12,8"
                                    BorderBrush="{DynamicResource Border0Brush}"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <icons:Icon Grid.Column="0" Kind="Globe" Size="14"
                                                Foreground="{DynamicResource Text2Brush}"
                                                VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Margin="10,0,8,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text0Brush}" />
                                        <TextBlock Text="{Binding Url}" FontSize="10"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource Text2Brush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Classes="smallAction"
                                            Tag="{Binding}" Click="OnEdit_Click"
                                            Content="Edit URL" />
                                    <Button Grid.Column="3" Classes="smallAction"
                                            Tag="{Binding}" Click="OnRemove_Click"
                                            Foreground="{DynamicResource StatusErrBrush}"
                                            Content="Remove" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
