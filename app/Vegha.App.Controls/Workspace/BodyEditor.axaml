<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels"
             xmlns:ws="using:Vegha.App.Controls.Workspace"
             xmlns:icons="using:Vegha.App.Controls.Icons"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="320"
             x:Class="Vegha.App.Controls.Workspace.BodyEditor"
             x:DataType="vm:RequestEditorViewModel">
    <!-- Grid (not DockPanel) so the visible body-mode editor always fills the available
         space. With DockPanel, only the *last* child fills; the others default to Dock=Left
         and auto-size to their content width — which made the raw editor visibly narrow,
         pushing its vertical scrollbar inward and trailing a "right edge" line through the
         text. All six children share the cell; IsVisible bindings ensure only one paints. -->
    <Grid Background="{DynamicResource CodeBgBrush}">
        <!-- (The body-type dropdown + Prettify live on the sub-tab header row in
             RequestWorkspace.axaml so they sit on the same line as Body / Headers / Auth /
             etc., right-aligned. They appear only when the Body sub-tab is active.) -->

        <!-- GraphQL editor, Postman-style layout: schema pane (Builder tree / Docs explorer)
             on the LEFT composes the query; the query text + variables live on the right. -->
        <Grid IsVisible="{Binding BodyType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=graphql}"
              ColumnDefinitions="340,4,*">

            <!-- Schema pane: Builder (checkbox tree) / Docs (explorer) toggle. Populated by
                 Introspect or silently from the per-endpoint schema cache. -->
            <DockPanel Grid.Column="0" Background="{DynamicResource Bg3Brush}">
                <Border DockPanel.Dock="Top" Padding="10,2" Height="22"
                        BorderBrush="{DynamicResource Border0Brush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                        <ToggleButton Grid.Column="0"
                                      IsChecked="{Binding !GraphQLDocsMode}"
                                      Content="Builder"
                                      FontSize="10"
                                      Padding="8,0" Height="18" MinHeight="0"
                                      ToolTip.Tip="Compose the query by checking schema fields" />
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding GraphQLDocsMode}"
                                      Content="Docs"
                                      FontSize="10"
                                      Padding="8,0" Height="18" MinHeight="0"
                                      Margin="4,0,0,0"
                                      ToolTip.Tip="Browse the schema documentation" />
                        <Button Grid.Column="3" x:Name="ViewSdlButton"
                                IsVisible="{Binding GraphQLSchemaLoaded}"
                                Content="SDL"
                                FontSize="10"
                                Background="Transparent"
                                Foreground="{DynamicResource Text2Brush}"
                                Padding="6,0" Height="18"
                                ToolTip.Tip="View the schema as SDL text" />
                        <Button Grid.Column="4"
                                IsVisible="{Binding GraphQLSchemaLoaded}"
                                Command="{Binding RefreshGraphQLSchemaCommand}"
                                Content="↻"
                                FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource Text2Brush}"
                                Padding="6,0" Height="18"
                                ToolTip.Tip="Re-introspect the endpoint (drops the cached schema)" />
                    </Grid>
                </Border>
                <Grid>
                    <!-- No schema yet: hint + the Introspect entry point. -->
                    <StackPanel IsVisible="{Binding !GraphQLSchemaLoaded}" Spacing="8" Margin="10,8">
                        <TextBlock IsVisible="{Binding GraphQLSchemaHint, Converter={x:Static ObjectConverters.IsNull}}"
                                   Text="No schema loaded. Introspect the endpoint to build queries by checking fields, browse docs, and get autocomplete. Known endpoints restore from the local cache automatically."
                                   FontSize="11"
                                   Foreground="{DynamicResource Text3Brush}"
                                   TextWrapping="Wrap" />
                        <TextBlock IsVisible="{Binding GraphQLSchemaHint, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   Text="{Binding GraphQLSchemaHint}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Text3Brush}"
                                   TextWrapping="Wrap" />
                        <Button Command="{Binding IntrospectGraphQLCommand}"
                                Content="Introspect schema"
                                FontSize="11"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White"
                                Padding="10,4"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="POST the standard introspection query to the URL (uses the request's headers + auth)" />
                    </StackPanel>

                    <!-- Border keeps the editor VM DataContext so IsVisible can bind to it;
                         only the child control's DataContext switches to the child VM. -->
                    <Border IsVisible="{Binding GraphQLSchemaLoaded}">
                        <Grid>
                            <Border IsVisible="{Binding !GraphQLDocsMode}">
                                <ws:GraphQLQueryBuilderView DataContext="{Binding QueryBuilder}" />
                            </Border>
                            <Border IsVisible="{Binding GraphQLDocsMode}">
                                <ws:GraphQLSchemaExplorer DataContext="{Binding SchemaExplorer}" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </DockPanel>

            <!-- Visible resting background: a transparent 4px strip between two identical
                 dark panes is undiscoverable — the hairline says "grab here". -->
            <GridSplitter Grid.Column="1" Classes="col"
                          Background="{DynamicResource Border0Brush}"
                          ToolTip.Tip="Drag to resize the schema pane" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="160" MinHeight="80" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Background="{DynamicResource CodeBgBrush}">
                    <Border DockPanel.Dock="Top" Padding="12,2" Height="22"
                            BorderBrush="{DynamicResource Border0Brush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="QUERY"
                                       Classes="sectionHeaderMinor"
                                       VerticalAlignment="Center" />
                            <!-- WS endpoint override — appears only when the active operation
                                 is a subscription. Empty derives ws(s):// from the URL bar. -->
                            <TextBox Grid.Column="1"
                                     IsVisible="{Binding IsActiveOperationSubscription}"
                                     Text="{Binding GraphQLWsUrlOverride, Mode=TwoWay}"
                                     Watermark="ws(s):// endpoint (blank = derive from URL)"
                                     FontSize="10"
                                     MinHeight="18" Height="18"
                                     Margin="10,0,8,0"
                                     Padding="6,0"
                                     VerticalAlignment="Center"
                                     ToolTip.Tip="Subscriptions stream over WebSocket. Leave blank to derive ws:// or wss:// from the request URL; set this when the server uses a different WebSocket endpoint." />
                            <!-- Operation picker: only relevant when the document defines
                                 several named operations; Send runs the selected one. -->
                            <ComboBox Grid.Column="2"
                                      IsVisible="{Binding HasMultipleGraphQLOperations}"
                                      ItemsSource="{Binding GraphQLOperationNames}"
                                      SelectedItem="{Binding SelectedGraphQLOperationName, Mode=TwoWay}"
                                      FontSize="10"
                                      MinHeight="20" Height="20"
                                      Padding="6,0"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Operation to execute (documents with multiple operations must name one)" />
                        </Grid>
                    </Border>
                    <Grid>
                        <ws:VariableAwareTextEditor
                            Text="{Binding GraphQLQuery, Mode=TwoWay}"
                            Variables="{Binding ResolvedVariablesSnapshot}"
                            GraphQLSchema="{Binding GraphQLSchemaModel}"
                            SingleLine="False"
                            ShowLineNumbers="True"
                            Bordered="False"
                            SyntaxHighlightingName="GraphQL"
                            CompletionMode="GraphQL"
                            FontSize="{DynamicResource EditorFontSize}" />
                        <!-- Designed empty state (same pattern as the response pane's
                             "No response yet"). Hit-test transparent so clicking anywhere
                             focuses the editor underneath and typing dismisses it. -->
                        <StackPanel IsVisible="{Binding GraphQLQuery, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                    IsHitTestVisible="False"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Spacing="12" MaxWidth="380">
                            <Border Width="52" Height="52" CornerRadius="26"
                                    Background="{DynamicResource Bg3Brush}"
                                    HorizontalAlignment="Center">
                                <icons:Icon Kind="Code" Size="22"
                                            Foreground="{DynamicResource Text3Brush}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="No query yet"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text1Brush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Check fields in the Builder to compose one, or start typing here. Introspect the schema for docs and autocomplete."
                                       FontSize="12"
                                       Foreground="{DynamicResource Text2Brush}"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <Border Background="{DynamicResource Bg3Brush}"
                                    BorderBrush="{DynamicResource Border1Brush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="10,4" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Ctrl + Space"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text1Brush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Autocomplete"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text2Brush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </DockPanel>

                <GridSplitter x:Name="QueryVariablesSplitter" Grid.Row="1" Classes="row"
                              Background="{DynamicResource Border0Brush}"
                              DoubleTapped="OnQueryVariablesSplitterDoubleTapped"
                              ToolTip.Tip="Drag to resize the variables pane — double-click to reset" />

                <DockPanel Grid.Row="2" Background="{DynamicResource CodeBgBrush}">
                    <Border DockPanel.Dock="Top" Padding="12,4" Height="22"
                            BorderBrush="{DynamicResource Border0Brush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="VARIABLES (JSON)"
                                       Classes="sectionHeaderMinor"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding GenerateGraphQLVariablesCommand}"
                                    Content="Generate"
                                    FontSize="10"
                                    Background="Transparent"
                                    Foreground="{DynamicResource Text2Brush}"
                                    Padding="8,0" Height="18"
                                    ToolTip.Tip="Fill a JSON skeleton for the $variables the current operation declares (keeps values you already set)" />
                        </Grid>
                    </Border>
                    <Grid>
                        <ws:VariableAwareTextEditor
                            Text="{Binding GraphQLVariables, Mode=TwoWay}"
                            Variables="{Binding ResolvedVariablesSnapshot}"
                            SingleLine="False"
                            ShowLineNumbers="True"
                            SyntaxHighlightingName="Json"
                            Bordered="False"
                            FontSize="{DynamicResource EditorFontSize}" />
                        <!-- Compact empty state (the pane is short — icon circle omitted,
                             typography matches the response pane's empty state). -->
                        <StackPanel IsVisible="{Binding GraphQLVariables, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                    IsHitTestVisible="False"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Spacing="6" MaxWidth="380">
                            <TextBlock Text="No variables"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text1Brush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Declare $variables in the query, then Generate scaffolds their JSON here."
                                       FontSize="11"
                                       Foreground="{DynamicResource Text2Brush}"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- Raw editor (json / xml / text / sparql) — variable-aware + line numbers + syntax.
             Borderless so the body area renders flush with no boxed input chrome. -->
        <ws:VariableAwareTextEditor
            IsVisible="{Binding IsBodyRaw}"
            Text="{Binding BodyContent, Mode=TwoWay}"
            Variables="{Binding ResolvedVariablesSnapshot}"
            SyntaxHighlightingName="{Binding BodySyntaxHighlightingName}"
            SingleLine="False"
            ShowLineNumbers="True"
            Bordered="False"
            FontSize="{DynamicResource EditorFontSize}"
            Watermark="(empty body — pick a type and start typing)" />

        <!-- Form URL-Encoded body — key/value table. The wire form is
             application/x-www-form-urlencoded; the executor encodes via FormUrlEncodedContent. -->
        <DockPanel IsVisible="{Binding BodyType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=form-urlencoded}"
                   Background="{DynamicResource CodeBgBrush}">
            <Border DockPanel.Dock="Top" Padding="12,6"
                    Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource Border0Brush}"
                    BorderThickness="0,0,0,1">
                <!-- No "+ Add row" — the table keeps a blank trailing row that grows as
                     the user types into it, matching the Params / Headers editors. -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="application/x-www-form-urlencoded"
                               Classes="sectionHeaderMinor"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            <ScrollViewer Background="{DynamicResource Bg2Brush}">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="32,*,*,30" Margin="12,8,12,4">
                        <TextBlock Grid.Column="1" Text="Name" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text2Brush}" />
                        <TextBlock Grid.Column="2" Text="Value" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text2Brush}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding FormUrlEncodedItems}" Margin="12,0,12,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:KvEntry">
                                <Grid ColumnDefinitions="32,*,*,30" Margin="0,2,0,0">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                              IsVisible="{Binding !IsBlank}"
                                              VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                             Watermark="key"
                                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                                             Background="{DynamicResource BgInputBrush}"
                                             BorderBrush="{DynamicResource Border1Brush}"
                                             Foreground="{DynamicResource Text0Brush}"
                                             Padding="6,3" CornerRadius="3" Margin="0,0,4,0" />
                                    <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay}"
                                             Watermark="value"
                                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                                             Background="{DynamicResource BgInputBrush}"
                                             BorderBrush="{DynamicResource Border1Brush}"
                                             Foreground="{DynamicResource Text0Brush}"
                                             Padding="6,3" CornerRadius="3" Margin="0,0,4,0" />
                                    <Button Grid.Column="3"
                                            Command="{Binding $parent[UserControl].((vm:RequestEditorViewModel)DataContext).RemoveFormUrlEncodedItemCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding !IsBlank}"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="6,2" Margin="4,0,0,0"
                                            ToolTip.Tip="Remove">
                                        <TextBlock Text="×" FontSize="14"
                                                   Foreground="{DynamicResource Text3Brush}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Multipart-form body — full 4-column grid with per-row text/file picker, optional
             per-part Content-Type override, and an "+ Add" / "+ File" pair to add rows. -->
        <DockPanel IsVisible="{Binding BodyType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=multipart-form}"
                   Background="{DynamicResource CodeBgBrush}">
            <Border DockPanel.Dock="Top" Padding="12,6"
                    Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource Border0Brush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="multipart/form-data"
                               Classes="sectionHeaderMinor"
                               VerticalAlignment="Center" />
                    <Button Content="+ Text row"
                            Command="{Binding AddMultipartTextItemCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentBrush}"
                            FontSize="11" Padding="6,2" />
                    <Button Content="+ File row"
                            Command="{Binding AddMultipartFileItemCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentBrush}"
                            FontSize="11" Padding="6,2" />
                </StackPanel>
            </Border>
            <ScrollViewer Background="{DynamicResource Bg2Brush}">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="32,*,*,140,90,Auto" Margin="12,8,12,4">
                        <TextBlock Grid.Column="1" Text="Name" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text2Brush}" />
                        <TextBlock Grid.Column="2" Text="Value" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text2Brush}" />
                        <TextBlock Grid.Column="3" Text="Content-Type" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text2Brush}" />
                        <TextBlock Grid.Column="4" Text="Kind" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text2Brush}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding MultipartItems}" Margin="12,0,12,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MultipartFormRow">
                                <Grid ColumnDefinitions="32,*,*,140,90,Auto" Margin="0,2,0,0">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsActive, Mode=TwoWay}"
                                              VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                             Watermark="field-name"
                                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                                             Background="{DynamicResource BgInputBrush}"
                                             BorderBrush="{DynamicResource Border1Brush}"
                                             Foreground="{DynamicResource Text0Brush}"
                                             Padding="6,3" CornerRadius="3" Margin="0,0,4,0" />
                                    <Grid Grid.Column="2" ColumnDefinitions="*,Auto" Margin="0,0,4,0">
                                        <TextBox Grid.Column="0" Text="{Binding Value, Mode=TwoWay}"
                                                 Watermark="value or /path/to/file"
                                                 FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                 Background="{DynamicResource BgInputBrush}"
                                                 BorderBrush="{DynamicResource Border1Brush}"
                                                 Foreground="{DynamicResource Text0Brush}"
                                                 Padding="6,3" CornerRadius="3" />
                                        <!-- Per-row file picker. Visible for both kinds — picking forces Kind=file. -->
                                        <Button Grid.Column="1"
                                                Command="{Binding $parent[UserControl].((vm:RequestEditorViewModel)DataContext).PickMultipartFileCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="6,2" Margin="2,0,0,0"
                                                ToolTip.Tip="Pick a file">
                                            <icons:Icon Kind="FolderOpen" Size="14" Foreground="{DynamicResource Text2Brush}" />
                                        </Button>
                                    </Grid>
                                    <TextBox Grid.Column="3" Text="{Binding ContentType, Mode=TwoWay}"
                                             Watermark="(auto)"
                                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                                             Background="{DynamicResource BgInputBrush}"
                                             BorderBrush="{DynamicResource Border1Brush}"
                                             Foreground="{DynamicResource Text0Brush}"
                                             Padding="6,3" CornerRadius="3" Margin="0,0,4,0" />
                                    <ComboBox Grid.Column="4" SelectedItem="{Binding Kind, Mode=TwoWay}"
                                              ItemsSource="{Binding $parent[UserControl].((vm:RequestEditorViewModel)DataContext).AvailableMultipartKinds}"
                                              Height="24" FontSize="11"
                                              Background="{DynamicResource Bg3Brush}"
                                              BorderBrush="{DynamicResource Border1Brush}" />
                                    <Button Grid.Column="5"
                                            Command="{Binding $parent[UserControl].((vm:RequestEditorViewModel)DataContext).RemoveMultipartItemCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="6,2" Margin="4,0,0,0"
                                            ToolTip.Tip="Remove">
                                        <TextBlock Text="×" FontSize="14"
                                                   Foreground="{DynamicResource Text3Brush}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock IsVisible="{Binding !MultipartItems.Count}"
                               Text="(no fields — click '+ Text row' or '+ File row')"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{DynamicResource Text3Brush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,16" />
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- File / Binary body — single file picker with optional Content-Type override -->
        <DockPanel IsVisible="{Binding BodyType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=file}"
                   Background="{DynamicResource CodeBgBrush}">
            <Border DockPanel.Dock="Top" Padding="12,8">
                <StackPanel Spacing="10">
                    <TextBlock Text="The selected file is streamed verbatim as the request body. Content-Type defaults to the file extension."
                               FontSize="11" FontStyle="Italic"
                               Foreground="{DynamicResource Text3Brush}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="tertiary"
                                Content="Pick file…"
                                Command="{Binding PickBodyFileCommand}" />
                        <Button Classes="secondary"
                                Content="Clear"
                                Command="{Binding ClearBodyFileCommand}"
                                IsVisible="{Binding FilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                    <Border IsVisible="{Binding FilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="{DynamicResource Bg2Brush}"
                            BorderBrush="{DynamicResource Border0Brush}"
                            BorderThickness="1" CornerRadius="3" Padding="8,6">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding FilePath}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="11"
                                       Foreground="{DynamicResource Text1Brush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Content-Type override (optional)" FontSize="11"
                                   Foreground="{DynamicResource Text2Brush}" />
                        <TextBox Text="{Binding FileContentType, Mode=TwoWay}"
                                 Watermark="(auto-detect from extension)"
                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                 Background="{DynamicResource BgInputBrush}"
                                 BorderBrush="{DynamicResource Border1Brush}"
                                 Foreground="{DynamicResource Text0Brush}"
                                 Padding="8,6" CornerRadius="3" MaxWidth="320" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DockPanel>

        <!-- "none" empty state — centered title + subtitle, matching the response pane's
             empty-state typography instead of a lone italic line in the top-left corner. -->
        <Border IsVisible="{Binding BodyType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=none}"
                Padding="20" Background="{DynamicResource Bg2Brush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="6" MaxWidth="320" Margin="0,0,0,60">
                <TextBlock Text="No body will be sent"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text1Brush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Pick a body type from the dropdown above to add one."
                           FontSize="11"
                           Foreground="{DynamicResource Text2Brush}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
