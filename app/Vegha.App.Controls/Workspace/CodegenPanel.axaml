<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels"
             xmlns:ws="using:Vegha.App.Controls.Workspace"
             xmlns:icons="using:Vegha.App.Controls.Icons"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="600"
             x:Class="Vegha.App.Controls.Workspace.CodegenPanel"
             x:DataType="vm:CodegenViewModel">
    <UserControl.Styles>
        <!-- Pill-style language buttons. Active pill takes the accent brush; inactive is a
             subtle Bg3 fill with a 1px border. Matches the Bruno reference. -->
        <Style Selector="Button.langPill">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,2,4,2" />
            <Setter Property="MinWidth" Value="60" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource Text1Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border1Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.langPill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
        </Style>
        <Style Selector="Button.langPill.active">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.langPill.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.langPill.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Header icon-only buttons (Copy, Close) — borderless, hover tints. -->
        <Style Selector="Button.headerIcon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.headerIcon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Bg3Brush}" />
        </Style>
    </UserControl.Styles>

    <DockPanel Background="{DynamicResource Bg2Brush}">
        <Border DockPanel.Dock="Top" Padding="10,8" Height="34"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="CODE SNIPPET"
                           FontSize="10" FontWeight="SemiBold"
                           LetterSpacing="1.2"
                           Foreground="{DynamicResource Text2Brush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="headerIcon"
                        Click="OnCopy_Click"
                        ToolTip.Tip="Copy snippet to clipboard">
                    <icons:Icon Kind="Copy" Size="14" />
                </Button>
                <Button Grid.Column="2" Classes="headerIcon"
                        Click="OnClose_Click"
                        Margin="2,0,0,0"
                        ToolTip.Tip="Close code panel — reopen via View ▸ Show code panel">
                    <TextBlock Text="✕" FontSize="13" />
                </Button>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Padding="10,6"
                BorderBrush="{DynamicResource Border0Brush}"
                BorderThickness="0,0,0,1">
            <ItemsControl ItemsSource="{Binding LanguagePills}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:LangPillViewModel">
                        <Button Classes="langPill"
                                Classes.active="{Binding IsActive}"
                                Content="{Binding DisplayName}"
                                Click="OnLanguage_Click"
                                Tag="{Binding Emitter}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Read-only code editor with line numbers + per-language syntax highlighting. -->
        <ws:ReadOnlyCodeView Text="{Binding Snippet}"
                             SyntaxHighlightingName="{Binding SyntaxHighlightingName}" />
    </DockPanel>
</UserControl>
