<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Vegha.App.ViewModels"
        xmlns:icons="using:Vegha.App.Controls.Icons"
        mc:Ignorable="d" d:DesignWidth="680" d:DesignHeight="460"
        x:Class="Vegha.App.Controls.Workspace.ManageCollectionsDialog"
        Title="Manage Collections"
        Width="680" Height="460"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner">
    <Window.Styles>
        <!-- Same rounded search-pill chrome as CollectionsPanel + AppTopBar. -->
        <Style Selector="Border.filterPill TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="Border.filterPill TextBox:focus /template/ Border">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.filterPill TextBox:pointerover /template/ Border">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.filterPill">
            <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border1Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="16">
        <!-- Header: title + subtitle (active workspace name) -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,12">
            <TextBlock Text="Manage Collections" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text0Brush}" />
            <TextBlock x:Name="SubtitleText" FontSize="11"
                       Foreground="{DynamicResource Text2Brush}" />
        </StackPanel>

        <!-- Footer: Create / Open / Import on the left, Close on the right. The left-cluster
             handlers reuse the AppTopBar entry points so the create/open/import code path is
             the same one users see from the "+" button. -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <Button Content="Create…" Click="OnCreate_Click"
                        Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource Border1Brush}"
                        Foreground="{DynamicResource Text0Brush}"
                        Padding="14,6" CornerRadius="3" />
                <Button Content="Open…" Click="OnOpen_Click"
                        Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource Border1Brush}"
                        Foreground="{DynamicResource Text0Brush}"
                        Padding="14,6" CornerRadius="3" />
                <Button Content="Import…" Click="OnImport_Click"
                        Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource Border1Brush}"
                        Foreground="{DynamicResource Text0Brush}"
                        Padding="14,6" CornerRadius="3" />
            </StackPanel>
            <Button Grid.Column="1" Content="Close" Click="OnClose_Click"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="18,6" CornerRadius="3"
                    FontWeight="SemiBold" />
        </Grid>

        <!-- Search bar -->
        <Border DockPanel.Dock="Top" Classes="filterPill" Height="30"
                Padding="10,0,4,0" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <icons:Icon Grid.Column="0" Kind="Search" Size="13"
                            Foreground="{DynamicResource Text2Brush}"
                            VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         x:Name="FilterBox"
                         Watermark="Search collections in this workspace…"
                         FontSize="12"
                         Foreground="{DynamicResource Text0Brush}"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Margin="8,0,0,0" />
                <Button Grid.Column="2" Click="OnClearFilter_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" Width="22" Height="22"
                        Margin="4,0,2,0" CornerRadius="3"
                        Cursor="Hand" ToolTip.Tip="Clear filter"
                        IsVisible="False" x:Name="ClearFilterButton">
                    <icons:Icon Kind="Close" Size="10"
                                Foreground="{DynamicResource Text2Brush}" />
                </Button>
            </Grid>
        </Border>

        <!-- Empty-state placeholder (visible when no collections match). -->
        <TextBlock x:Name="EmptyState"
                   DockPanel.Dock="Top"
                   Text="No collections in this workspace yet. Use Create… / Open… / Import… below."
                   FontSize="11" FontStyle="Italic"
                   Foreground="{DynamicResource Text3Brush}"
                   TextAlignment="Center"
                   Margin="0,40,0,0"
                   IsVisible="False" />

        <ListBox Name="CollectionList"
                 Background="{DynamicResource Bg2Brush}"
                 BorderBrush="{DynamicResource Border1Brush}"
                 BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:CollectionRootViewModel">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="2,6">
                        <icons:Icon Grid.Column="0" Kind="Collection" Size="16"
                                    Margin="2,0,12,0" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource Text0Brush}" />
                            <TextBlock Text="{Binding SourcePath}" FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource Text2Brush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Activate" Click="OnActivate_Click"
                                Tag="{Binding}"
                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                BorderThickness="0" Padding="8,4" FontSize="11" />
                        <Button Grid.Column="3" Content="Rename" Click="OnRename_Click"
                                Tag="{Binding}"
                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                BorderThickness="0" Padding="8,4" FontSize="11" />
                        <Button Grid.Column="4" Content="Reveal" Click="OnReveal_Click"
                                Tag="{Binding}"
                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                BorderThickness="0" Padding="8,4" FontSize="11" />
                        <Button Grid.Column="5" Content="Remove" Click="OnRemove_Click"
                                Tag="{Binding}"
                                Background="Transparent" Foreground="{DynamicResource Text2Brush}"
                                BorderThickness="0" Padding="8,4" FontSize="11" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
