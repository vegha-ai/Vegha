<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ws="using:Vegha.App.Controls.Workspace"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="640"
        x:Class="Vegha.App.Controls.Workspace.WorkspaceEditorDialog"
        Title="Edit Workspace"
        Width="1100" Height="700"
        MinWidth="720" MinHeight="480"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner">
    <ws:WorkspaceEditor x:Name="Editor" />
</Window>
