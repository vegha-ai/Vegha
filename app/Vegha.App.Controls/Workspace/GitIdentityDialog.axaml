<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="440" d:DesignHeight="220"
        x:Class="Vegha.App.Controls.Workspace.GitIdentityDialog"
        Title="Git user identity"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="20">
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto" Margin="0,16,0,0">
            <Border Grid.Column="0" />
            <Button Grid.Column="1" Content="Cancel" Click="OnCancel_Click"
                    Background="Transparent"
                    BorderBrush="{DynamicResource Border1Brush}"
                    BorderThickness="1"
                    Foreground="{DynamicResource Text0Brush}"
                    Padding="14,6" Margin="0,0,8,0"
                    CornerRadius="4" />
            <Button Grid.Column="2" Content="Save" Click="OnOk_Click"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="18,6"
                    CornerRadius="4"
                    FontWeight="SemiBold" />
        </Grid>
        <StackPanel Spacing="10">
            <TextBlock Text="These values write to the repository's local git config."
                       FontSize="11" Foreground="{DynamicResource Text2Brush}" />
            <StackPanel Spacing="3">
                <TextBlock Text="user.name" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text2Brush}" />
                <TextBox x:Name="NameBox" FontSize="13"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}" Padding="8,6" />
            </StackPanel>
            <StackPanel Spacing="3">
                <TextBlock Text="user.email" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text2Brush}" />
                <TextBox x:Name="EmailBox" FontSize="13"
                         Background="{DynamicResource BgInputBrush}"
                         BorderBrush="{DynamicResource Border1Brush}"
                         Foreground="{DynamicResource Text0Brush}" Padding="8,6" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
