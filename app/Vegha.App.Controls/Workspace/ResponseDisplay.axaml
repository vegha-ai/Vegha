<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Vegha.App.ViewModels"
             xmlns:ws="using:Vegha.App.Controls.Workspace"
             xmlns:icons="using:Vegha.App.Controls.Icons"
             xmlns:conv="using:Vegha.App.Controls.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="360"
             x:Class="Vegha.App.Controls.Workspace.ResponseDisplay"
             x:DataType="vm:RequestEditorViewModel">
    <Border Background="{DynamicResource Bg2Brush}">
      <Grid>
        <DockPanel>
            <!-- Status line -->
            <Border DockPanel.Dock="Top" Padding="12,8" Height="36"
                    BorderBrush="{DynamicResource Border0Brush}"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*">
                    <TextBlock Grid.Column="0" Text="RESPONSE"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text2Brush}"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center" />

                    <!-- (empty-state hint moved into the response body below) -->

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                Margin="0,0,14,0"
                                IsVisible="{Binding HasResponse}"
                                VerticalAlignment="Center">
                        <TextBlock Text="Status:" Foreground="{DynamicResource Text2Brush}" FontSize="11" />
                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding ResponseStatusCode, Converter={x:Static conv:StatusCategoryToBrushConverter.Instance}}">
                            <Run Text="{Binding ResponseStatusCode}" />
                            <Run Text=" " />
                            <Run Text="{Binding ResponseStatusText}" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                Margin="0,0,14,0"
                                IsVisible="{Binding HasResponse}"
                                VerticalAlignment="Center">
                        <TextBlock Text="Time:" Foreground="{DynamicResource Text2Brush}" FontSize="11" />
                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource Text0Brush}">
                            <Run Text="{Binding ResponseElapsedMilliseconds}" />
                            <Run Text=" ms" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding HasResponse}"
                                VerticalAlignment="Center">
                        <TextBlock Text="Size:" Foreground="{DynamicResource Text2Brush}" FontSize="11" />
                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource Text0Brush}">
                            <Run Text="{Binding ResponseBody.Length}" />
                            <Run Text=" chars" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error banner -->
            <Border DockPanel.Dock="Top"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Background="{DynamicResource StatusErrSoftBrush}"
                    BorderBrush="{DynamicResource StatusErrBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource StatusErrBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Border>

            <!-- GraphQL subscription timeline — docked above the response tabs while a
                 graphql-ws session has produced frames; picking a row shows it below. -->
            <ws:GraphQLSubscriptionView DockPanel.Dock="Top"
                                        IsVisible="{Binding HasSubscriptionFrames}" />

            <!-- Body area: response subtabs once a response exists, otherwise a
                 designed empty state (audit §07.3). The Grid lets the empty state
                 fill the body region below the status line. -->
            <Grid>
            <TabControl Classes="subtabs"
                        IsVisible="{Binding HasResponse}"
                        SelectedIndex="{Binding ResponseTabIndex}">
                <!-- Body — switches between text / image / PDF based on Content-Type.
                     Uses Grid (not DockPanel) for the body-mode children so the active
                     editor always fills the cell. With DockPanel, only the LAST child
                     auto-fills; siblings default to Dock=Left and auto-size to their
                     content width — which made the ReadOnlyCodeView visibly narrow and
                     pushed AvaloniaEdit's V-scrollbar inward to the right edge of the
                     longest line of text (visible as a "scrollbar trailing the text"
                     for long single-line responses). Same fix as BodyEditor.axaml. -->
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Body" />
                    </TabItem.Header>
                    <Grid Background="{DynamicResource CodeBgBrush}"
                          RowDefinitions="Auto,*">
                        <!-- Toolbar: filter / format dropdown / Save. Wrap toggle removed (body
                             already wraps by default). Pretty-XML toggle removed — the Format
                             dropdown's JSON/XML modes auto-prettify via PrettyByFormat, so a
                             separate toggle was redundant and inconsistent with the request side. -->
                        <Border Grid.Row="0" Padding="10,4"
                                Background="{DynamicResource Bg2Brush}"
                                BorderBrush="{DynamicResource Border0Brush}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding JsonPathFilter}"
                                         IsVisible="{Binding ResponseIsJson}"
                                         Watermark="JSONPath filter — e.g. $.users[*].email"
                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                         Background="{DynamicResource BgInputBrush}"
                                         BorderBrush="{DynamicResource Border1Brush}"
                                         Foreground="{DynamicResource Text0Brush}"
                                         Padding="6,3" CornerRadius="3" />
                                <TextBlock Grid.Column="0"
                                           Text="{Binding ResponseContentType}"
                                           IsVisible="{Binding !ResponseIsJson}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="10"
                                           Foreground="{DynamicResource Text3Brush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center" Margin="6,0,0,0">
                                    <!-- "Formatting…" hint during background pretty-print of multi-MB
                                         JSON/XML. The viewer shows the raw body immediately and
                                         swaps to formatted output when this flips off. -->
                                    <TextBlock Text="Formatting…"
                                               IsVisible="{Binding IsPrettifying}"
                                               FontSize="11" FontStyle="Italic"
                                               Foreground="{DynamicResource Text2Brush}"
                                               VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{Binding AvailableResponseFormats}"
                                              SelectedItem="{Binding ResponseFormat}"
                                              MinWidth="80" Height="22"
                                              FontSize="11"
                                              VerticalAlignment="Center"
                                              ToolTip.Tip="Pick the display format. Auto picks based on Content-Type; Raw shows bytes verbatim." />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Name="SaveResponseButton"
                                        Click="OnSaveResponse_Click"
                                        IsVisible="{Binding HasResponse}"
                                        Content="Save…"
                                        FontSize="10"
                                        Background="{DynamicResource Bg3Brush}"
                                        Foreground="{DynamicResource Text0Brush}"
                                        Padding="10,3" Margin="6,0,0,0"
                                        ToolTip.Tip="Save the raw response body to a file" />
                            </Grid>
                        </Border>

                        <!-- All three body-mode views share Grid.Row=1 — only the one whose
                             IsVisible binding fires paints. With every child filling the cell,
                             the active editor takes the full viewport width and AvaloniaEdit's
                             V-scrollbar sits at the right edge of the viewport, never inside
                             the content. -->

                        <!-- Text view (default for non-binary) — AvaloniaEdit-based read-only editor
                             gives line numbers + syntax highlighting + selection. WordWrap is bound
                             to ResponseWordWrap (default true) so long lines don't cause horizontal
                             scrolling — which avoids AvaloniaEdit's V-scrollbar drift bug.
                             Hidden for multi-MB bodies: AvaloniaEdit's TextView re-measures every
                             visible visual-line on each click/keystroke, which locks the UI on
                             huge documents even when highlighting is off. -->
                        <ws:ReadOnlyCodeView Grid.Row="1"
                                             IsVisible="{Binding UseRichResponseViewer}"
                                             Text="{Binding DisplayedBody}"
                                             SyntaxHighlightingName="{Binding ResponseSyntaxHighlightingName}"
                                             WordWrap="{Binding ResponseWordWrap}" />

                        <!-- Canvas-painted viewer for large bodies. Owns multi-line drag selection,
                             Ctrl+A / Ctrl+C clipboard, and per-line JSON/XML token highlighting.
                             Lives inside a ScrollViewer with logical scrolling — the canvas
                             implements ILogicalScrollable in lines/chars units. -->
                        <ScrollViewer Grid.Row="1"
                                      IsVisible="{Binding UseLargeResponseViewer}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{DynamicResource CodeBgBrush}">
                            <ws:CanvasTextView Text="{Binding DisplayedBody}"
                                               SyntaxKind="{Binding ResponseCanvasSyntaxKind, Converter={x:Static ws:CanvasSyntaxConverter.Instance}}"
                                               FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                                               FontSize="{DynamicResource EditorFontSize}" />
                        </ScrollViewer>

                        <!-- Image preview for image/* responses. -->
                        <ScrollViewer Grid.Row="1"
                                      IsVisible="{Binding ResponseIsImage}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{DynamicResource Bg2Brush}">
                            <Border Padding="12">
                                <Image Source="{Binding ResponseBodyBytes, Converter={StaticResource BytesToBitmapConverter}}"
                                       Stretch="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>
                        </ScrollViewer>

                        <!-- PDF preview placeholder; rendered by code-behind once PdfPig is wired (3.1c). -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding ResponseIsPdf}"
                                Padding="14,12"
                                Background="{DynamicResource Bg2Brush}">
                            <ContentControl Name="PdfPreviewHost" />
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Cookies — parsed from Set-Cookie headers on this response. -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Cookies" />
                            <Border Classes="countPill">
                                <TextBlock Text="{Binding ResponseCookies.Count}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text1Brush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer Background="{DynamicResource Bg2Brush}">
                        <Grid>
                            <TextBlock IsVisible="{Binding !ResponseCookies.Count}"
                                       Text="No Set-Cookie headers in this response."
                                       Foreground="{DynamicResource Text3Brush}"
                                       FontSize="11" FontStyle="Italic"
                                       Padding="14,12" />
                            <ItemsControl ItemsSource="{Binding ResponseCookies}"
                                          IsVisible="{Binding !!ResponseCookies.Count}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ResponseCookieRow">
                                        <Border BorderBrush="{DynamicResource Border0Brush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="12,8">
                                            <StackPanel Spacing="2">
                                                <Grid ColumnDefinitions="180,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{DynamicResource Text0Brush}" />
                                                    <SelectableTextBlock Grid.Column="1"
                                                                         Text="{Binding Value}"
                                                                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                                         Foreground="{DynamicResource Text0Brush}"
                                                                         TextWrapping="Wrap" />
                                                </Grid>
                                                <Grid ColumnDefinitions="180,*">
                                                    <TextBlock Grid.Column="0" Text="Domain · Path"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource Text2Brush}" />
                                                    <TextBlock Grid.Column="1"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                               Foreground="{DynamicResource Text2Brush}">
                                                        <Run Text="{Binding Domain}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding Path}" />
                                                    </TextBlock>
                                                </Grid>
                                                <Grid ColumnDefinitions="180,*"
                                                      IsVisible="{Binding FlagsLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                    <TextBlock Grid.Column="0" Text="Flags"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource Text2Brush}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding FlagsLabel}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                               Foreground="{DynamicResource Text2Brush}" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Headers -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Headers" />
                            <Border Classes="countPill">
                                <TextBlock Text="{Binding ResponseHeaders.Count}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text1Brush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer Background="{DynamicResource Bg2Brush}">
                        <ItemsControl ItemsSource="{Binding ResponseHeaders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HeaderRow">
                                    <Border BorderBrush="{DynamicResource Border0Brush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,6">
                                        <Grid ColumnDefinitions="240,*">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource Text1Brush}"
                                                       VerticalAlignment="Top" />
                                            <SelectableTextBlock Grid.Column="1"
                                                                 Text="{Binding Value}"
                                                                 FontFamily="{StaticResource MonoFont}"
                                                                 FontSize="12"
                                                                 Foreground="{DynamicResource Text0Brush}"
                                                                 TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <!-- Test Results -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Test Results" />
                            <Border Classes="countPill">
                                <TextBlock Text="{Binding TestResults.Count}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text1Brush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer Background="{DynamicResource Bg2Brush}">
                        <StackPanel>
                            <!-- Bruno-style summary: Tests (N), Passed: X, Failed: Y -->
                            <Border Padding="12,8" IsVisible="{Binding HasTestResults}"
                                    BorderBrush="{DynamicResource Border0Brush}" BorderThickness="0,0,0,1">
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text0Brush}">
                                    <Run Text="Tests (" /><Run Text="{Binding TestResults.Count}" /><Run Text="),  Passed: " /><Run
                                        Text="{Binding TestsPassedCount}" Foreground="{DynamicResource StatusOkBrush}" /><Run Text="   Failed: " /><Run
                                        Text="{Binding TestsFailedCount}" Foreground="{DynamicResource StatusErrBrush}" />
                                </TextBlock>
                            </Border>
                            <ItemsControl ItemsSource="{Binding TestResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TestResultRow">
                                        <Border BorderBrush="{DynamicResource Border0Brush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="12,8">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="✓" FontSize="13" FontWeight="Bold"
                                                                   Foreground="{DynamicResource StatusOkBrush}"
                                                                   IsVisible="{Binding Passed}" />
                                                        <TextBlock Text="✗" FontSize="13" FontWeight="Bold"
                                                                   Foreground="{DynamicResource StatusErrBrush}"
                                                                   IsVisible="{Binding !Passed}" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource Text0Brush}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <SelectableTextBlock Text="{Binding FailureMessage}"
                                                                         FontFamily="{StaticResource MonoFont}"
                                                                         FontSize="11"
                                                                         Foreground="{DynamicResource StatusErrBrush}"
                                                                         Margin="20,2,0,0"
                                                                         TextWrapping="Wrap"
                                                                         IsVisible="{Binding !Passed}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource Text3Brush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="{Binding DurationMs, StringFormat={}{0:F1}}" />
                                                    <Run Text=" ms" />
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Timeline -->
                <TabItem Header="Timeline">
                    <ScrollViewer Background="{DynamicResource Bg2Brush}">
                        <Border Padding="14,12">
                            <StackPanel Spacing="14">
                                <TextBlock FontSize="12" Foreground="{DynamicResource Text1Brush}">
                                    <Run Text="Total · " />
                                    <Run Text="{Binding TimingTotalMs, StringFormat={}{0:F1}}" />
                                    <Run Text=" ms" />
                                </TextBlock>

                                <!-- Stacked phase bar -->
                                <Border BorderBrush="{DynamicResource Border0Brush}" BorderThickness="1" CornerRadius="3"
                                        Height="22">
                                    <ItemsControl ItemsSource="{Binding TimelinePhases}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TimelinePhase">
                                                <Border Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                        Width="{Binding WidthRatio, Converter={StaticResource RatioToWidthConverter}, ConverterParameter=600}"
                                                        Height="20"
                                                        ToolTip.Tip="{Binding Name}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Per-phase legend rows -->
                                <ItemsControl ItemsSource="{Binding TimelinePhases}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TimelinePhase">
                                            <Grid ColumnDefinitions="14,180,*,Auto" Margin="0,2">
                                                <Border Grid.Column="0" Width="10" Height="10" CornerRadius="2"
                                                        Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           Margin="6,0,0,0" FontSize="12"
                                                           Foreground="{DynamicResource Text1Brush}"
                                                           VerticalAlignment="Center" />
                                                <ProgressBar Grid.Column="2"
                                                             Minimum="0" Maximum="1"
                                                             Value="{Binding WidthRatio}"
                                                             Foreground="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                             Background="{DynamicResource Bg3Brush}"
                                                             Height="6"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="3"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Text0Brush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="{Binding DurationMs, StringFormat={}{0:F1}}" />
                                                    <Run Text=" ms" />
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="DNS / TCP / TLS phases are 0 on reused connections (HTTP keep-alive)."
                                           Foreground="{DynamicResource Text3Brush}"
                                           FontSize="10" FontStyle="Italic"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- (Sent tab moved into the request pane — it shows the *outgoing* payload,
                     conceptually a request-side concern, not a response-side one.) -->

                <!-- Raw — canvas-painted viewer (same control the Body tab uses for large
                     bodies) so a multi-MB raw response renders fluidly. The canvas
                     implements ILogicalScrollable, so a single ScrollViewer drives both
                     axes; the V-scrollbar sits at the viewport's right edge naturally
                     (no need for the old nested-ScrollViewer workaround that fixed
                     SelectableTextBlock's scrollbar drift). AllowAutoHide=False kept
                     so the bar lives in a dedicated chrome column. -->
                <TabItem Header="Raw">
                    <ScrollViewer Name="RawOuterScroll"
                                  Background="{DynamicResource CodeBgBrush}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  AllowAutoHide="False">
                        <ws:CanvasTextView Text="{Binding RawResponseText}"
                                           SyntaxKind="None"
                                           FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                                           FontSize="{DynamicResource EditorFontSize}" />
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- Empty state — shown until the first response arrives. -->
            <StackPanel IsVisible="{Binding !HasResponse}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12" MaxWidth="380">
                <Border Width="52" Height="52" CornerRadius="26"
                        Background="{DynamicResource Bg3Brush}"
                        HorizontalAlignment="Center">
                    <icons:Icon Kind="Send" Size="22"
                                Foreground="{DynamicResource Text3Brush}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="No response yet"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text1Brush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Send this request and the response — status, headers, timing and body — appears here."
                           FontSize="12"
                           Foreground="{DynamicResource Text2Brush}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" />
                <Border Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource Border1Brush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,4" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Name="SendShortcutChip"
                                   Text="Ctrl + Enter"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Text1Brush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Send"
                                   FontSize="11"
                                   Foreground="{DynamicResource Text2Brush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
            </Grid>
        </DockPanel>

        <!-- Busy overlay — covers the entire response panel while a request is in flight.
             Shows a live elapsed timer, a slowly-spinning indicator, and a Cancel button
             bound to CancelSendCommand. IsHitTestVisible swallows clicks so the underlying
             tab buttons don't fire mid-request. -->
        <Border IsVisible="{Binding IsSending}"
                Background="#CC1A1B26"
                IsHitTestVisible="True">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14">
                <TextBlock Text="{Binding SendingElapsedDisplay}"
                           FontSize="32"
                           FontWeight="Light"
                           Foreground="{DynamicResource Text0Brush}"
                           HorizontalAlignment="Center" />

                <!-- Wrap the icon in a Border whose RenderTransform we animate. Animating
                     the icon directly fights the Viewbox/Canvas the Icon control builds
                     internally, and Avalonia 11 has no default animator for RenderTransform
                     as a whole — you must give the element a RotateTransform up front and
                     animate its Angle. -->
                <Border HorizontalAlignment="Center"
                        Width="22" Height="22"
                        RenderTransformOrigin="50%,50%">
                    <Border.RenderTransform>
                        <RotateTransform Angle="0" />
                    </Border.RenderTransform>
                    <Border.Styles>
                        <Style Selector="Border">
                            <Style.Animations>
                                <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="RotateTransform.Angle" Value="0.0" />
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="RotateTransform.Angle" Value="360.0" />
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Border.Styles>
                    <icons:Icon Kind="Refresh"
                                Size="22"
                                Foreground="{DynamicResource Text2Brush}" />
                </Border>

                <Button Content="Cancel Request"
                        Command="{Binding CancelSendCommand}"
                        HorizontalAlignment="Center"
                        Padding="18,8"
                        Background="{DynamicResource Bg3Brush}"
                        Foreground="{DynamicResource Text0Brush}"
                        BorderBrush="{DynamicResource Border1Brush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        FontSize="12"
                        Cursor="Hand" />
            </StackPanel>
        </Border>
      </Grid>
    </Border>
</UserControl>
