<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Vegha.App.ViewModels"
        xmlns:icons="using:Vegha.App.Controls.Icons"
        mc:Ignorable="d" d:DesignWidth="680" d:DesignHeight="460"
        x:Class="Vegha.App.Controls.Workspace.ImportSummaryDialog"
        Title="Import Complete"
        Width="680" Height="460"
        MinWidth="520" MinHeight="360"
        Background="{DynamicResource Bg1Brush}"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
    <DockPanel Margin="16">
        <!-- Header: success glyph + count + active workspace name. -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,12" Padding="12,10"
                Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="{DynamicResource AccentBrush}"
                        VerticalAlignment="Center">
                    <TextBlock Text="✓" FontSize="16" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="2">
                    <TextBlock x:Name="HeaderText" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text0Brush}" />
                    <TextBlock x:Name="SubtitleText" FontSize="11"
                               Foreground="{DynamicResource Text2Brush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer: Close button right-aligned. No secondary actions — the user wanted a
             single, focused next-step path (Open / Rename per row, then Close). -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <Button Grid.Column="1" Content="Close" Click="OnClose_Click"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="22,6" CornerRadius="3"
                    FontWeight="SemiBold" />
        </Grid>

        <!-- Imported-collection list. One row per just-imported collection with per-row
             actions (Activate / Reveal / Rename / Remove). Mirrors the ManageCollectionsDialog
             row template but is scoped to the import session only. -->
        <ListBox Name="CollectionList"
                 Background="{DynamicResource Bg2Brush}"
                 BorderBrush="{DynamicResource Border1Brush}"
                 BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:CollectionRootViewModel">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="2,6">
                        <icons:Icon Grid.Column="0" Kind="Collection" Size="16"
                                    Margin="2,0,12,0" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource Text0Brush}" />
                            <TextBlock Text="{Binding SourcePath}" FontSize="10"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource Text2Brush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Open" Click="OnActivate_Click"
                                Tag="{Binding}"
                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                BorderThickness="0" Padding="8,4" FontSize="11" />
                        <Button Grid.Column="3" Content="Rename" Click="OnRename_Click"
                                Tag="{Binding}"
                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                BorderThickness="0" Padding="8,4" FontSize="11" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
