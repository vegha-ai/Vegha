# Normalize text files to LF in the repo and check them out with LF on every
# platform. Without this, the Windows CI runner's default core.autocrlf=true
# converts LF to CRLF on checkout, and parsers / exact-string assertions that
# don't expect CR characters fail there but pass locally (and vice versa).
* text=auto eol=lf

# Windows-only scripts must keep CRLF — cmd.exe / older PowerShell hosts
# choke on LF-only line endings.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Bruno / API test fixtures: enforce LF so body-block byte comparisons are
# deterministic across platforms.
*.bru       text eol=lf

# Common binary formats — never line-end munge these.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.7z        binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.snk       binary
*.pfx       binary
*.p12       binary
*.appx      binary
*.msix      binary
*.nupkg     binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
