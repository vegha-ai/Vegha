meta {
  name: graphql-countries
}

vars {
  gqlUrl: https://countries.trevorblades.com/graphql
}

docs {
  Sample GraphQL collection against the public Countries API
  (countries.trevorblades.com — no auth, introspection enabled).

  Open a request, click "Introspect schema" once to light up the docs explorer
  and schema-aware autocomplete (the schema is cached locally afterwards), then
  Ctrl+Enter to send. Try Ctrl+Space inside the query editor.
}
